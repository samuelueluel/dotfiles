{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "provider": {
    "ramalama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "apiKey": "dummy"
      },
      "models": {
        // MoE everyday driver — serve-qwen-moe
        "unsloth/Qwen3.6-35B-A3B-MTP-GGUF": {
          "name": "Qwen3.6 35B-A3B MoE",
          "temperature": true,
          "limit": { "context": 131072, "output": 16384 }
        },
        // Dense reasoning — serve-qwen-dense
        "unsloth/Qwen3.6-27B-MTP-GGUF": {
          "name": "Qwen3.6 27B Dense",
          "temperature": true,
          "limit": { "context": 131072, "output": 32768 }
        },
        // Copyediting / hard math — serve-gemma4-dense (no MTP)
        "unsloth/gemma-4-31b-it-GGUF": {
          "name": "Gemma 4 31B",
          "temperature": true,
          "limit": { "context": 131072, "output": 16384 }
        }
      }
    }
  },
  "model": "ramalama/unsloth/Qwen3.6-35B-A3B-MTP-GGUF",
  // Explicit sampling params for OpenCode's three built-in modes.
  // /no_think is intentionally absent — it is a soft prefix, not a hard toggle, so it is unreliable.
  // The model decides when to think based on task difficulty.
  "agent": {
    "build": { "temperature": 0.6, "top_p": 0.95 },
    "plan":  { "temperature": 0.6, "top_p": 0.95 },
    "agent": { "temperature": 0.7, "top_p": 0.8 }
  },
  "mcp": {
    "searxng": {
      "enabled": true,
      "type": "local",
      "command": ["/var/home/samuel/.config/opencode/searxng-venv/bin/python3"],
      "args": [
        "/var/home/samuel/.config/opencode/searxng_mcp.py"
      ]
    },
    "stata": {
      "enabled": true,
      "type": "local",
      "command": ["uvx"],
      "args": [
        "mcp-stata"
      ]
    }
  }
}
