{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Noctalia Blur",
  "author": "Samuel",
  "themes": [
    {
      "name": "Noctalia Blur",
      "appearance": "dark",
      "style": {
        "accents": [
          "#1AAAD4",
          "#E06840",
          "#7DC4A0"
        ],
        "background.appearance": "transparent",
        "background": "#7A2E2EE6",

        // Make all major surface layers fully transparent so they don't stack
        "elevated_surface.background": "#7A2E2EFF",
        "surface.background": "#00000000",
        "panel.background": "#00000000",
        "pane.background": "#00000000",
        "editor.background": "#00000000",
        "editor.gutter.background": "#00000000",
        "terminal.background": "#00000000",

        // Bars and Toolbar
        "status_bar.background": "#7A2E2EE6",
        "title_bar.background": "#7A2E2EE6",
        "title_bar.inactive_background": "#7A2E2EE6",
        "toolbar.background": "#00000000",
        "tab_bar.background": "#00000000",
        "tab.inactive_background": "#00000000",
        "tab.active_background": "#00000000",

        "border": "#4A202090",
        "border.variant": "#4A202090",
        "border.focused": "#1AAAD480",
        "border.selected": "#E0684080",
        "border.transparent": "#00000000",

        "element.background": "#00000015",
        "element.hover": "#E0684015",
        "element.active": "#E0684025",
        "element.selected": "#1AAAD444",

        "ghost_element.background": null,
        "ghost_element.hover": "#E0684010",
        "ghost_element.active": "#E0684020",
        "ghost_element.selected": "#1AAAD430",

        "text": "#F2F0EC",
        "text.muted": "#ABABAB",
        "text.placeholder": "#ABABAB99",
        "text.accent": "#1AAAD4",
        "icon": "#F2F0EC",
        "icon.accent": "#1AAAD4",

        "search.match_background": "#005B6180",
        "search.active_match_background": "#1AAAD480",

        "players": [
          {
            "cursor": "#1AAAD4",
            "selection": "#1AAAD480"
          }
        ],

        "scrollbar.thumb.background": "#00000030",
        "scrollbar.thumb.border": "#00000000",
        "scrollbar.track.background": "#00000010",
        "scrollbar.track.border": "#6B334870",

        "editor.foreground": "#F2F0EC",
        "editor.line_number": "#F2F0EC60",
        "editor.active_line_number": "#F2F0EC",
        "editor.active_line.background": "#00000015",

        "terminal.foreground": "#F2F0EC",
        "terminal.ansi.black": "#F2F0EC",
        "terminal.ansi.red": "#FFA726",
        "terminal.ansi.green": "#7DC4A0",
        "terminal.ansi.yellow": "#D0A7AF",
        "terminal.ansi.blue": "#1AAAD4",
        "terminal.ansi.magenta": "#E06840",
        "terminal.ansi.cyan": "#1AAAD4",
        "terminal.ansi.white": "#D0A7AF",

        "syntax": {
          "attribute": { "color": "#7DC4A0", "font_weight": 600 },
          "boolean": { "color": "#FFA726", "font_weight": 600 },
          "comment": { "color": "#ABABAB", "font_style": "italic", "font_weight": 600 },
          "constant": { "color": "#FFA726", "font_weight": 600 },
          "function": { "color": "#1AAAD4", "font_weight": 600 },
          "keyword": { "color": "#E06840", "font_weight": 600 },
          "number": { "color": "#FFA726", "font_weight": 600 },
          "operator": { "color": "#1AAAD4", "font_weight": 600 },
          "string": { "color": "#7DC4A0", "font_weight": 600 },
          "type": { "color": "#D0A7AF", "font_weight": 600 },
          "variable": { "color": "#F2F0EC", "font_weight": 600 }
        }
      }
    }
  ]
}
