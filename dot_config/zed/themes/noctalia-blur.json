{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Noctalia Blur",
  "author": "Samuel",
  "themes": [
    {
      "name": "Noctalia Blur",
      "appearance": "dark",
      "style": {
        "accents": [
          "#00B6C2",
          "#cc72fc",
          "#17C182"
        ],
        "background.appearance": "transparent",
        "background": "#914059E6",

        // Make all major surface layers fully transparent so they don't stack
        "elevated_surface.background": "#00000000",
        "surface.background": "#00000000",
        "panel.background": "#00000000",
        "pane.background": "#00000000",
        "editor.background": "#00000000",
        "editor.gutter.background": "#00000000",
        "terminal.background": "#00000000",

        // Bars and Toolbar
        "status_bar.background": "#914059E6",
        "title_bar.background": "#914059E6",
        "title_bar.inactive_background": "#914059E6",
        "toolbar.background": "#00000000",
        "tab_bar.background": "#00000000",
        "tab.inactive_background": "#00000000",
        "tab.active_background": "#00000000",

        "border": "#6B334890",
        "border.variant": "#6B334890",
        "border.focused": "#00B6C280",
        "border.selected": "#cc72fc80",
        "border.transparent": "#00000000",

        "element.background": "#00000015",
        "element.hover": "#cc72fc15",
        "element.active": "#cc72fc25",
        "element.selected": "#00B6C244",

        "ghost_element.background": null,
        "ghost_element.hover": "#cc72fc10",
        "ghost_element.active": "#cc72fc20",
        "ghost_element.selected": "#00B6C230",

        "text": "#FFFFFF",
        "text.muted": "#ABABAB",
        "text.placeholder": "#ABABAB99",
        "text.accent": "#00B6C2",
        "icon": "#FFFFFF",
        "icon.accent": "#00B6C2",

        "scrollbar.thumb.background": "#00000030",
        "scrollbar.thumb.border": "#00000000",
        "scrollbar.track.background": "#00000010",
        "scrollbar.track.border": "#6B334870",

        "editor.foreground": "#FFFFFF",
        "editor.line_number": "#FFFFFF60",
        "editor.active_line_number": "#FFFFFF",
        "editor.active_line.background": "#00000015",

        "terminal.foreground": "#FFFFFF",
        "terminal.ansi.black": "#FFFFFF",
        "terminal.ansi.red": "#FFA726",
        "terminal.ansi.green": "#17C182",
        "terminal.ansi.yellow": "#D0A7AF",
        "terminal.ansi.blue": "#00B6C2",
        "terminal.ansi.magenta": "#cc72fc",
        "terminal.ansi.cyan": "#00B6C2",
        "terminal.ansi.white": "#D0A7AF",

        "syntax": {
          "attribute": { "color": "#17C182", "font_weight": 700 },
          "boolean": { "color": "#FFA726", "font_weight": 700 },
          "comment": { "color": "#ABABAB", "font_style": "italic", "font_weight": 700 },
          "constant": { "color": "#FFA726", "font_weight": 700 },
          "function": { "color": "#00B6C2", "font_weight": 700 },
          "keyword": { "color": "#cc72fc", "font_weight": 700 },
          "number": { "color": "#FFA726", "font_weight": 700 },
          "operator": { "color": "#00B6C2", "font_weight": 700 },
          "string": { "color": "#17C182", "font_weight": 700 },
          "type": { "color": "#D0A7AF", "font_weight": 700 },
          "variable": { "color": "#FFFFFF", "font_weight": 700 }
        }
      }
    }
  ]
}
