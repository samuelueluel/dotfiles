// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "cli_default_open_behavior": "new_window",
  "ui_font_weight": 500.0,
  "preview_tabs": {
    "enabled": true
  },
  "tab_bar": {
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": true
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_user_picture": true,
    "show_user_menu": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_menus": true,
    "show_sign_in": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "button": true,
    "dock": "right"
  },
  "agent": {
    "default_model": {
      "provider": "ramalama-local",
      "model": "unsloth/Qwen3.6-35B-A3B-MTP-GGUF"
    },
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
    // Workaround for Zed bug #53135: buffer_codegen's streaming path can't handle
    // thinking/reasoning tokens and aborts (no diff). Disabling streaming tools fixes
    // inline assist for local thinking models. (agent panel uses the non-streaming path.)
    "inline_assistant_use_streaming_tools": false
  },
  // Local Ramalama :8080 — for inline assist, agent panel, git commit messages, etc.
  // API key: set RAMALAMA_LOCAL_API_KEY=dummy in your environment (or zed won't connect)
  "language_models": {
    "openai_compatible": {
      "ramalama-local": {
        "api_url": "http://localhost:8080/v1",
        "available_models": [
          {
            "name": "unsloth/Qwen3.6-35B-A3B-MTP-GGUF",
            "display_name": "Qwen3.6-35B (local)",
            "max_tokens": 131072,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": true
            }
          }
        ]
      }
    }
  },
  // OpenCode via ACP — reads model config from ~/.config/opencode/opencode.jsonc (local Ramalama :8080)
  "agent_servers": {
    "OpenCode": {
      "type": "custom",
      "command": "/home/linuxbrew/.linuxbrew/bin/opencode",
      "args": ["acp", "--cwd", "/var/home/samuel"]
    },
    "Goose": {
      "type": "custom",
      "command": "goose",
      "args": ["acp"]
    }
  },
  // FIM edit prediction — Qwen2.5-Coder-1.5B on :8081 (start with: serve-autocomplete)
  // To re-enable: change provider back to "open_ai_compatible_api"
  "edit_predictions": {
    "provider": "none"
  },
  "git_panel": {
    "dock": "right"
  },
  "buffer_font_weight": 600.0,
  "project_panel": {
    "dock": "right",
    "button": true
  },
  "ui_font_family": "IBM Plex Sans",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "session": {
    "trust_all_worktrees": true,
    "restore_unsaved_buffers": false
  },
  "restore_on_startup": "none",
  "telemetry": {
    "diagnostics": true,
    "metrics": true
  },
  "ui_font_size": 17.0,
  "buffer_font_size": 15,
  "window_decorations": "server",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "New Mexico"
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "minimap": {
    "show": "always"
  }
}
