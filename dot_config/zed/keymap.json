[
  {
    "bindings": {
      "ctrl-q": "pane::CloseActiveItem"
    }
  },
  {
    "context": "Workspace && !ProjectPanel",
    "bindings": {
      "ctrl-left": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-left": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-left": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-space": "command_palette::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-space": "editor::Newline",
      "ctrl-space": "command_palette::Toggle",
      "ctrl-r": "editor::ReloadFile",
      "ctrl-shift-z": "editor::Redo",
      "shift-enter": ["task::Spawn", { "task_name": "Run selection in Stata" }]
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-tab": "tab_switcher::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-tab": "tab_switcher::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-tab": [
        "tab_switcher::Toggle",
        {
          "select_last": true
        }
      ]
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-tab": [
        "tab_switcher::Toggle",
        {
          "select_last": true
        }
      ]
    }
  }
]