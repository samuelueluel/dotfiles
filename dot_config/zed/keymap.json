[
  {
    "bindings": {
      "ctrl-q": "pane::CloseActiveItem"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-space": "command_palette::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-space": "command_palette::Toggle",
      "ctrl-r": "editor::ReloadFile",
      "ctrl-q": "editor::DeleteToPreviousWordStart",
      "ctrl-w": "editor::Backspace",
      "alt-w": "editor::MoveUp",
      "alt-a": "editor::MoveLeft",
      "alt-s": "editor::MoveDown",
      "alt-d": "editor::MoveRight",
      "alt-q": "editor::MoveToBeginningOfLine",
      "alt-e": "editor::MoveToEndOfLine"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-tab": "tab_switcher::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-tab": "tab_switcher::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-tab": [
        "tab_switcher::Toggle",
        {
          "select_last": true
        }
      ]
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-tab": [
        "tab_switcher::Toggle",
        {
          "select_last": true
        }
      ]
    }
  }
]
