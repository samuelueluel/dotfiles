// This config is in the KDL format: https://kdl.dev
// "/-" comments out the following node.
// Check the wiki for a full description of the configuration:
// https://yalter.github.io/niri/Configuration:-Introduction
//


// ============================================================
// NAMED WORKSPACES
// ============================================================

workspace "casual"
workspace "utility"
workspace "work"

// ============================================================
// CURSOR
// ============================================================

cursor {
    xcursor-theme "oreo_spark_orange_cursors"
    xcursor-size 32
}

// ============================================================
// ENVIRONMENT
// ============================================================

environment {
    QT_QPA_PLATFORMTHEME "qt6ct"
    XCURSOR_THEME "oreo_spark_orange_cursors"
    XCURSOR_SIZE "32"
    PATH "{{ .chezmoi.homeDir }}/.local/bin:{{ .chezmoi.homeDir }}/.cargo/bin:{{ .chezmoi.homeDir }}/.npm-global/bin:/home/linuxbrew/.linuxbrew/bin:/usr/local/sbin:/usr/local/bin:/usr/bin:/usr/sbin"
}

// ============================================================
// INPUT
// ============================================================

input {
    mod-key-nested "Super"
    keyboard {
        xkb {
            // I don't use this because I want Caps Lock = Mod even if not using Niri
            //options "caps:menu" // caps:super = Caps Lock becomes Mod, altwin:menu_win = Physical Start button becomes the 'Menu' key
        }
        numlock // Enable numlock on startup, omitting this setting disables it.
    }

    touchpad {
        // off
        tap
        accel-speed 0.2
    }

    mouse {
    }

    trackpoint {
    }
}

// ============================================================
// OUTPUTS (MONITORS)
// ============================================================

output "HDMI-A-1" {
    scale 2
    position x=0 y=0
}

output "eDP-1" {
    scale 1.25 // Niri default for this screen, 1536x864 logical
    position x=192 y=1080 // 192 centers the 1536px laptop screen under the 1920px TV screen
}

// ============================================================
// LAYOUT
// ============================================================

layout {
    gaps 5 // was 4

    background-color "#000000"

    //center-focused-column "never"
    center-focused-column "always"

    default-column-width { proportion 0.76666667; }

    preset-column-widths {
        proportion 1.0
        proportion 0.66666667
        proportion 0.5
        proportion 0.33333333
    }

    preset-window-heights {
        proportion 1.0
        proportion 0.66666667
        proportion 0.5
        proportion 0.33333333
    }

    focus-ring {
        off
        //width 2
        //active-color "#00B6C2"  //theme turquoise
    }

    border {
        //off
        width 2 // **don't remove this comment, it's needed by niri-tile-toggle**
        active-color "#00B6C2"  // theme turquoise
        inactive-color "#D0A7AF" // theme dusty rose
        urgent-color "#EE9D00" // theme gold
    }

    shadow {
    }

    struts {
        left 0
        right 0
        top 0
        bottom 0
    }

    tab-indicator {
        place-within-column
        position "right"
        hide-when-single-tab

        gap 2
        width 8
        length total-proportion=1.0

        active-color "#FFA726" // theme gold
        inactive-color "#00000090"   // black at ~50% opacity
    }
}

// ============================================================
// GENERAL SETTINGS
// ============================================================

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

hotkey-overlay {
    skip-at-startup
}

animations {
    // off

    slowdown 1.3 // Slow down all animations by this factor. Values below 1 speed them up instead.

    // Active shader: circle  (switch with: niri-shader <name>)
    window-open {
        duration-ms 750
        curve "ease-out-cubic"
        custom-shader r"
            // Ported from gl-transitions/circleopen.glsl (MIT, gre)

            vec4 open_color(vec3 coords_geo, vec3 size_geo) {
                float p = niri_clamped_progress;
                vec2 uv = coords_geo.xy;
                float seed = niri_random_seed;

                float smoothness = 0.3;
                float SQRT_2 = 1.414213562;

                vec2 center = vec2(0.5 + (seed - 0.5) * 0.15, 0.5 + (seed * 0.7 - 0.35) * 0.15);

                float dist = SQRT_2 * distance(center, uv);
                float m = smoothstep(-smoothness, 0.0, dist - p * (1.0 + smoothness));
                float reveal = 1.0 - m;

                vec3 tc = niri_geo_to_tex * vec3(uv, 1.0);
                vec4 color = texture2D(niri_tex, tc.st);

                return color * reveal;
            }
        "
    }
    window-close {
        duration-ms 750
        curve "ease-out-cubic"
        custom-shader r"
            // Ported from gl-transitions/circleopen.glsl (MIT, gre)

            vec4 close_color(vec3 coords_geo, vec3 size_geo) {
                float p = niri_clamped_progress;
                vec2 uv = coords_geo.xy;
                float seed = niri_random_seed;

                float smoothness = 0.3;
                float SQRT_2 = 1.414213562;

                // Slightly randomized center
                vec2 center = vec2(0.5 + (seed - 0.5) * 0.15, 0.5 + (seed * 0.7 - 0.35) * 0.15);

                float dist = SQRT_2 * distance(center, uv);
                float m = smoothstep(-smoothness, 0.0, dist - (1.0 - p) * (1.0 + smoothness));
                float remain = 1.0 - m;

                vec3 tc = niri_geo_to_tex * vec3(uv, 1.0);
                vec4 color = texture2D(niri_tex, tc.st);

                return color * remain;
            }
        "
    }
}

overview {
    zoom 0.4
}

gestures {
    hot-corners {
        off // This turns off hardcoded top left hot corner
    }
}

// ============================================================
// STARTUP
// ============================================================

// ── Shell (Noctalia) ──────────────────────────────────────────────────────
// See end of file
// spawn-at-startup "sh" "-c" "sleep 2 && qs -c noctalia-shell" // I think this fails without sh and sleep 2 (v4)

// ── Clipboard daemon ──────────────────────────────────────────────────────
spawn-at-startup "sh" "-c" "rm -f ~/.local/share/cclip/db.sqlite3* && cclipd -s 2 -t image/png -t 'image/*' -t 'text/plain;charset=utf-8' -t 'text/*'"

// ── Display management ────────────────────────────────────────────────────
spawn-at-startup "kanshi"

// ── Apps ──────────────────────────────────────────────────────────────────
spawn-at-startup "sh" "-c" "sleep 5 && dropbox start -i"
spawn-at-startup "sh" "-c" "sleep 5 && flatpak run com.github.wwmm.easyeffects --gapplication-service"
spawn-at-startup "/usr/bin/niriusd"
spawn-at-startup "udiskie" "--no-tray" // auto-mount USB / external drives
// mpris-proxy removed: airpods-media.service (evdev daemon) handles routing to Quod Libet directly

debug {
    honor-xdg-activation-with-invalid-serial
}

// ============================================================
// WINDOW RULES
// ============================================================

// --- Global Appearance ---

window-rule {
    geometry-corner-radius 1
    clip-to-geometry true
}

// --- Workspace Assignments and Proportions ---

window-rule {
    match app-id="zen-work"
    open-on-workspace "work"
    default-column-width { proportion 1.0; }
}

window-rule {
    match app-id="zen-personal"
    open-on-workspace "casual"
}

window-rule {
    match app-id="zen-personal"
    match app-id="io.github.quodlibet.QuodLibet"
    match app-id="rmpc"
    default-column-width { proportion 1.0; }
    //open-maximized-to-edges true
}

// --- Custom Floating Launchers ---

window-rule {
    match title="File Launcher" // Catch the specific window title we set in the bind command
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="Folder Launcher" // Catch the specific window title we set in the bind command
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="Yazi Float"
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 700; }
}

window-rule {
    match title="Keybind Search" // Catch the specific window title we set in the bind command
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 800; }
}

window-rule {
    match title="TV Hub"
    open-floating true
    default-column-width { proportion 0.996; }
    default-window-height { proportion 0.99; }
}

window-rule {
    match title="Ghostty Float"
    open-floating true
    default-column-width { fixed 700; }
    default-window-height { fixed 400; }
}

window-rule {
    match title="Obsidian Quick Note"
    open-floating true
    default-column-width { fixed 600; }
    default-window-height { fixed 500; }
}

window-rule {
    match title="rmpc Float"
    open-floating true
    default-column-width { fixed 1310; }
    default-window-height { fixed 695; }
}

window-rule {
    match title="Kitty Float Art"
    open-floating true
    default-column-width { fixed 1100; }
    default-window-height { fixed 500; }
}

window-rule {
    match title="wlctl"
    open-floating true
    default-column-width { fixed 800; }
    default-window-height { fixed 550; }
}

window-rule {
    match title="btm"
    open-floating true
    default-column-width { fixed 1200; }
    default-window-height { fixed 700; }
}

window-rule {
    match title="calcure"
    open-floating true
    default-column-width { fixed 1000; }
    default-window-height { fixed 700; }
}

window-rule {
    match title="bluetuith"
    open-floating true
    default-column-width { fixed 1000; }
    default-window-height { fixed 600; }
}

window-rule {
    match title="wiremix"
    open-floating true
    default-column-width { fixed 900; }
    default-window-height { fixed 500; }
}

// --- Opacity and Blur ---

// Base opacity --- exceptions below
window-rule {
    //match is-active=false
    //exclude is-floating=true
    opacity 0.9
    draw-border-with-background false
}

// Obsidian
window-rule {
    match app-id="obsidian"
    match app-id="com.stremio.stremio"
    opacity 1.0
}

window-rule { // transparency set in app-specific config to prevent text from dimming
    match app-id="com.mitchellh.ghostty"
    match app-id="kitty"
    match app-id="kitty-launcher"
    match title="Ghostty Float"
    match title="Obsidian Quick Note"
    match title="Keybind Search"
    match title="bluetuith"
    match title="btm"
    match title="calcure"
    match title="wlctl"
    match title="Yazi Float" // kitty config
    match app-id="dev.zed.Zed" // noctalia-blur theme
    opacity 1.0
}

// Blur for regular windows  ---  requires transparency for blur to work, set above
window-rule {
    match {}
    //exclude app-id="zen-personal"
    //exclude app-id="zen-work"
    background-effect {
        blur true
    }
}

// Opacity of non-focused windows --- must go below custom rules above
window-rule {
    match is-active=false
    //exclude is-floating=true
    opacity 0.5
    draw-border-with-background false
}

// Exceptions for full opacity
window-rule {
    match title="(?i)picture in picture|picture-in-picture"
    match app-id="zen-personal"
    match app-id="zen-work"
    match app-id="^mpv$"
    //match is-floating=true
    opacity 1.0
}

// Blur for pop-up menus
window-rule {
    match app-id="io.github.quodlibet.QuodLibet"
    match app-id="rmpc"
    match app-id="helium"
    match app-id="obsidian"

    popups {
        geometry-corner-radius 15

        background-effect {
            blur true
        }
    }
}

// Blur for special windows --- some particulars with geometry
layer-rule {
    match namespace="^launcher$"   // fuzzel; this still needed?
    geometry-corner-radius 10
    background-effect {
        blur true
    }
}

layer-rule {
    match namespace="^niri-minimap$"
    geometry-corner-radius 12
    background-effect {
        //blur true
    }
}

layer-rule {
    match namespace="^rofi$"
    geometry-corner-radius 8
    background-effect {
        blur true
    }
}


// ============================================================
// KEYBINDS
// ============================================================

recent-windows { // Disable hard-coded alt+tab binding
    binds {
    }
}

binds {

    // -----------------------------------
    // SYSTEM
    // -----------------------------------

    Ctrl+Alt+Delete hotkey-overlay-title="Log out" { quit; }
    Mod+Escape hotkey-overlay-title="Toggle keybind inhibitor for RD/VM" allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    // -----------------------------------
    // SHELL CONTROLS
    // -----------------------------------

    XF86MenuKB hotkey-overlay-title="Toggle minimap" repeat=false { spawn "niri-minimap"; }
    Mod+Space hotkey-overlay-title="Television Hub" repeat=false { spawn "kitty" "--config" "{{ .chezmoi.homeDir }}/.config/kitty/launcher.conf" "--class" "kitty-launcher" "--title" "TV Hub" "-e" "sh" "-c" "sleep 0.1 && exec /home/linuxbrew/.linuxbrew/bin/tv 'Television Hub'"; }
    Mod+Ctrl+Space hotkey-overlay-title="Launcher (rofi)" repeat=false { spawn "rofi" "-show" "drun"; }
    Mod+B hotkey-overlay-title="Toggle bar visibility" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "bar" "toggle"; }
    // Mod+Y hotkey-overlay-title="Toggle notification center" { spawn "qs" "ipc" "call" "notifications" "toggle"; }
    // Mod+X hotkey-overlay-title="Clear all notifications" { spawn "qs" "ipc" "call" "notifications" "clear"; }

    // -----------------------------------
    // APPLICATION LAUNCHERS
    // -----------------------------------

    Mod+Grave hotkey-overlay-title="Spawn Ghostty"  repeat=false { spawn "ghostty"; }
    Mod+Ctrl+Grave hotkey-overlay-title="Spawn floating Ghostty" repeat=false { spawn "ghostty" "--title=Ghostty Float"; }
    Mod+Ctrl+E hotkey-overlay-title="Spawn floating Yazi (auto-close on open)" repeat=false { spawn "env" "YAZI_FLOAT=1" "kitty" "--title" "Yazi Float" "-e" "zsh" "-c" "exec yazi"; }
    Mod+E hotkey-overlay-title="Spawn Yazi file manager" repeat=false { spawn "kitty" "--title" "yazi" "-e" "zsh" "-c" "exec yazi"; }
    Mod+N hotkey-overlay-title="Quick Note to Obsidian" repeat=false { spawn "ghostty" "--title=Obsidian Quick Note" "-e" "obsidian-quick-note.sh"; }

    // -----------------------------------
    // WINDOW MANAGEMENT
    // -----------------------------------

    Mod+Ctrl+Q hotkey-overlay-title="Close window"  repeat=false { spawn "/usr/bin/smart-close.sh"; }
    Mod+P hotkey-overlay-title="Toggle window floating" { toggle-window-floating; } // note this will also make non-floating windows sticky, but buggy
    Mod+Ctrl+P hotkey-overlay-title="Toggle window follow mode" { spawn "/usr/bin/nirius" "toggle-follow-mode"; }

    Mod+O hotkey-overlay-title="Toggle window scratchpad state" { spawn "/usr/bin/nirius" "scratchpad-toggle"; } // Oh not Zero
    Mod+0 hotkey-overlay-title="Show all scratchpad windows" { spawn "/usr/bin/nirius" "scratchpad-show-all"; }
    Mod+Ctrl+0 hotkey-overlay-title="Cycle scratchpad windows" { spawn "/usr/bin/nirius" "scratchpad-show"; }

    // Numbered Tags Binds — Mod+N focuses tag N, Mod+Ctrl+N sets/toggles tag N on focused window
    Mod+1 hotkey-overlay-title="Focus tag 1" { spawn "niri-tag" "focus" "1"; }
    Mod+2 hotkey-overlay-title="Focus tag 2" { spawn "niri-tag" "focus" "2"; }
    Mod+3 hotkey-overlay-title="Focus tag 3" { spawn "niri-tag" "focus" "3"; }
    Mod+Ctrl+1 hotkey-overlay-title="Set tag 1 on focused window" { spawn "niri-tag" "set" "1"; }
    Mod+Ctrl+2 hotkey-overlay-title="Set tag 2 on focused window" { spawn "niri-tag" "set" "2"; }
    Mod+Ctrl+3 hotkey-overlay-title="Set tag 3 on focused window" { spawn "niri-tag" "set" "3"; }

    Mod+G hotkey-overlay-title="Toggle fullscreen" { fullscreen-window; }
    Mod+Ctrl+G hotkey-overlay-title="Maximize window to edges" { maximize-window-to-edges; }
    Mod+F hotkey-overlay-title="Cycle column width" { switch-preset-column-width; }      // cycles over chosen presets
    Mod+Ctrl+F hotkey-overlay-title="Cycle window height" { switch-preset-window-height; } // cycles over chosen presets

    Mod+L hotkey-overlay-title="Toggle column tab mode" { toggle-column-tabbed-display; }

    Mod+Comma hotkey-overlay-title="Consume/expel window left"  { spawn "niri-nav" "consume-or-expel-window-left"; }
    Mod+Period hotkey-overlay-title="Consume/expel window right" { spawn "niri-nav" "consume-or-expel-window-right"; }
    //Mod+Ctrl+Shift+A hotkey-overlay-title="Consume/expel window left"  { spawn "niri-nav" "consume-or-expel-window-left"; }
    //Mod+Ctrl+Shift+D hotkey-overlay-title="Consume/expel window right" { spawn "niri-nav" "consume-or-expel-window-right"; }


    // -----------------------------------
    // FOCUS NAVIGATION
    // -----------------------------------

    Mod+W { spawn "niri-nav" "focus-window-or-workspace-up"; }
    Mod+A { spawn "niri-nav" "focus-column-left"; }
    Mod+S { spawn "niri-nav" "focus-window-or-workspace-down"; }
    Mod+D { spawn "niri-nav" "focus-column-right"; }

    Mod+Up    { focus-window-or-workspace-up; }
    Mod+Left  { focus-column-left; }
    Mod+Down  { focus-window-or-workspace-down; }
    Mod+Right { focus-column-right; }

    //Mod+I hotkey-overlay-title="Toggle focus mode (wallpaper + centering + opacity)" repeat=false { spawn "niri-mode-toggle"; }
    // NOTE: niri-tile-toggle script is fragile — it hardcodes gap/border values. Update the script if gaps or borders change in this config.
    Mod+I hotkey-overlay-title="Toggle tile-scroll mode (50% columns)" repeat=false { spawn "niri-tile-toggle"; }
    Mod+Ctrl+I hotkey-overlay-title="Resize right column to complement of focused" repeat=false { spawn "niri-complement-column"; }

    Mod+Tab hotkey-overlay-title="Focus previous window" { focus-window-previous; }

    // -----------------------------------
    // FOCUS/MOVE COLUMNS AND WINDOWS
    // -----------------------------------

    Mod+Ctrl+W { spawn "niri-nav" "move-window-up-or-to-workspace-up"; }
    Mod+Ctrl+A { spawn "niri-nav" "move-column-left"; }
    Mod+Ctrl+S { spawn "niri-nav" "move-window-down-or-to-workspace-down"; }
    Mod+Ctrl+D { spawn "niri-nav" "move-column-right"; }

    Mod+Ctrl+Up    { move-window-up-or-to-workspace-up; }
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Down  { move-window-down-or-to-workspace-down; }
    Mod+Ctrl+Right { move-column-right; }

    // -----------------------------------
    // RESIZE COLUMNS AND WINDOWS
    // -----------------------------------

    Mod+Minus      { set-column-width "-5%"; }
    Mod+Equal      { set-column-width "+5%"; }

    Mod+Ctrl+Minus { set-window-height "-5%"; }
    Mod+Ctrl+Equal { set-window-height "+5%"; }

    // -----------------------------------
    // FOCUS WINDOWS/WORKSPACES WITH MOUSE
    // -----------------------------------

    Mod+WheelScrollDown cooldown-ms=150 { focus-column-right; }
    Mod+WheelScrollUp   cooldown-ms=150 { focus-column-left; }

    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { focus-workspace-up; }

    // -----------------------------------
    // REORDER WORKSPACES
    // -----------------------------------

    Mod+Shift+Page_Down { move-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }

    // -----------------------------------
    // FOCUS/MOVE MONITOR
    // -----------------------------------

    Mod+Shift+A     { focus-monitor-left; }
    Mod+Shift+S     { focus-monitor-down; }
    Mod+Shift+W     { focus-monitor-up; }
    Mod+Shift+D     { focus-monitor-right; }

    Mod+Shift+Left  { focus-monitor-left; }
    Mod+Shift+Down  { focus-monitor-down; }
    Mod+Shift+Up    { focus-monitor-up; }
    Mod+Shift+Right { focus-monitor-right; }

    //Mod+Shift+Ctrl+A  { move-column-to-monitor-left; }
    //Mod+Shift+Ctrl+S  { move-column-to-monitor-down; }
    //Mod+Shift+Ctrl+W    { move-column-to-monitor-up; }
    //Mod+Shift+Ctrl+D { move-column-to-monitor-right; }

    //Mod+Shift+Ctrl+Left  { move-column-to-monitor-left; }
    //Mod+Shift+Ctrl+Down  { move-column-to-monitor-down; }
    //Mod+Shift+Ctrl+Up    { move-column-to-monitor-up; }
    //Mod+Shift+Ctrl+Right { move-column-to-monitor-right; }

    // -----------------------------------
    // SCROLL BINDS (COLUMN FOCUS AND MOVE)
    // -----------------------------------

    //Mod+WheelScrollRight      { focus-column-right; }
    //Mod+WheelScrollLeft       { focus-column-left; }
    //Mod+Ctrl+WheelScrollRight { move-column-right; }
    //Mod+Ctrl+WheelScrollLeft  { move-column-left; }

    //Mod+Shift+WheelScrollDown      { focus-column-right; }
    //Mod+Shift+WheelScrollUp        { focus-column-left; }
    //Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    //Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // -----------------------------------
    // MEDIA CONTROLS
    // -----------------------------------

    // XF86AudioPlay  { spawn "playerctl" "--player=quodlibet" "play-pause"; }
    // XF86AudioPause { spawn "playerctl" "--player=quodlibet" "play-pause"; }
    // XF86AudioNext  { spawn "playerctl" "--player=quodlibet" "next"; }
    // XF86AudioPrev  { spawn "playerctl" "--player=quodlibet" "previous"; }
    XF86AudioPlay  allow-when-locked=true { spawn "playerctl" "--player=mpd" "play-pause"; }
    XF86AudioPause allow-when-locked=true { spawn "playerctl" "--player=mpd" "play-pause"; }
    XF86AudioNext  allow-when-locked=true { spawn "playerctl" "--player=mpd" "next"; }
    XF86AudioPrev  allow-when-locked=true { spawn "playerctl" "--player=mpd" "previous"; }

    //Mod+Z hotkey-overlay-title="Play/pause Quod Libet"   { spawn "playerctl" "--player=quodlibet" "play-pause"; }
    Mod+Z hotkey-overlay-title="Play/pause rmpc (MPD)"   { spawn "rmpc" "togglepause"; }
    Mod+Ctrl+Z hotkey-overlay-title="Play/pause Zen" { spawn "playerctl" "--player=firefox" "play-pause"; }

    // -----------------------------------
    // VOLUME AND BRIGHTNESS
    // -----------------------------------

    XF86AudioRaiseVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    XF86AudioMute        allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"; }

    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "set" "5%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "set" "5%-"; }

    // -----------------------------------
    // SCREENSHOTS
    // -----------------------------------

    Print      { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print  { screenshot-window; }

}

// ============================================================
// MORE WINDOW RULES
// ============================================================

window-rule {
    match is-focused=true
    geometry-corner-radius 5
    clip-to-geometry true
}

window-rule {
    match is-focused=false
    geometry-corner-radius 35
    clip-to-geometry true
}

// ============================================================
// NOCTALIA
// ============================================================

spawn-at-startup "noctalia" // this was supposed to be at the end of the file
