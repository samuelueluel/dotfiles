[metadata]
name = "Notes (Obsidian)"
description = "Search Obsidian files by name"

[source]
# Target the vault directly
command = "fd -e md --base-directory {{ .chezmoi.homeDir }}/Dropbox/Sam_Personal_Vault"

[ui]
orientation = "portrait"

[preview]
command = "bat --color=always --style=plain \"{{ .chezmoi.homeDir }}/Dropbox/Sam_Personal_Vault/{}\""

[keybindings]
enter = "actions:obsidian-open"
alt-space = "actions:obsidian-open"

[actions.obsidian-open]
description = "Open in Obsidian (New Tab)"
command = "{{ .chezmoi.homeDir }}/.local/bin/tv-action-obsidian.sh '{split:\t:0}'"
mode = "execute"
