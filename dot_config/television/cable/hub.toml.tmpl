[metadata]
name = "Television Hub"
description = "Television hub containing favorite channels"

[source]
command = "{{ .chezmoi.homeDir }}/.local/bin/tv-hub-menu.sh"
display = "{split:\t:0}"

[ui]
ui_scale = 60

[ui.preview_panel]
hidden = true

[preview]
command = "echo 'Action: {}'"

[keybindings]
enter = "actions:hub-enter"
alt-space = "actions:hub-enter"

[actions.hub-enter]
description = "Execute selected hub workflow"
command = "{{ .chezmoi.homeDir }}/.local/bin/tv-hub-action.sh '{split:\t:1}'"
mode = "execute"
