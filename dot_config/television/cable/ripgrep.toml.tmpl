[metadata]
name = "Ripgrep"
description = "Search file content with Ripgrep"

[source]
command = "echo '󰩉 Start Ripgrep Search...'"

[ui]
orientation = "portrait"

[preview]
command = "echo 'This will prompt for a search query in your terminal.'"

[keybindings]
enter = "actions:launch"
alt-space = "actions:launch"

[actions.launch]
description = "Start interactive search"
command = "{{ .chezmoi.homeDir }}/.local/bin/tv-yazi-content.sh"
mode = "execute"
