[metadata]
name = "Snippets"
description = "Search and execute CLI snippets"

[source]
command = "grep -oP '^-\\s+\\K.*' /var/home/samuel/.config/television/snippets.md | sort"
display = "{split: | :0}"
no_sort = true

[preview]
command = "echo '{}' | awk -F '|' '{print $2}' | sed 's/^[[:space:]]*//'"

[keybindings]
enter = "actions:copy"
ctrl-c = "actions:copy"

[actions.copy]
description = "Copy snippet to clipboard"
command = "echo '{}' | awk -F '|' '{print $2}' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr -d '\\n' | wl-copy"
mode = "fork"
