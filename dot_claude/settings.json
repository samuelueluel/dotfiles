{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pw-play /usr/share/sounds/freedesktop/stereo/message.oga > /dev/null 2>&1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Claude Hook Ran\" >> /tmp/claude_hook.log && pw-play /usr/share/sounds/freedesktop/stereo/complete.oga > /dev/null 2>&1"
          }
        ]
      }
    ]

  },
  "effortLevel": "low",
  "theme": "custom:blur-theme"
}
