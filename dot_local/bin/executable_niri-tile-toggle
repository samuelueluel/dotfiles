#!/bin/bash
# Toggles between scroller mode and tile-scroll mode.
#
# Tile-scroll mode:
#   - All columns on ALL workspaces set to 50% width (two full columns always visible)
#   - center-focused-column never + gaps 2 + focus-ring width 0
#   - default-column-width 50% so new windows also open at 50%
#   - Black wallpaper
#
# Exit restores the full config snapshot taken at entry — no hardcoded default values.

CONFIG="$HOME/.config/niri/config.kdl"
BACKUP="$HOME/.cache/niri-config-backup.kdl"
STATE_FILE="$HOME/.cache/niri-tile-toggle"

resize_all_columns() {
    COLUMN_WIDTH="$1" python3 << 'EOF'
import os, json, subprocess, sys

width = os.environ['COLUMN_WIDTH']

win_res = subprocess.run(['niri', 'msg', '--json', 'windows'], capture_output=True, text=True)
win_data = json.loads(win_res.stdout)

focused_win_id = next((w['id'] for w in win_data if w.get('is_focused')), None)

# One representative window per column, across all workspaces
cols_by_ws = {}
for w in win_data:
    ws_id = w.get('workspace_id')
    if ws_id is None:
        continue
    pos = w['layout'].get('pos_in_scrolling_layout')
    if pos is None:
        continue
    col_idx = pos[0]
    key = (ws_id, col_idx)
    if key not in cols_by_ws:
        cols_by_ws[key] = w['id']

for win_id in sorted(cols_by_ws.values()):
    subprocess.run(['niri', 'msg', 'action', 'focus-window', '--id', str(win_id)])
    subprocess.run(['niri', 'msg', 'action', 'set-column-width', width])

# Restore original focus
if focused_win_id:
    subprocess.run(['niri', 'msg', 'action', 'focus-window', '--id', str(focused_win_id)])
EOF
}

if [ -f "$STATE_FILE" ]; then
    # EXITING TILE MODE → restore config snapshot taken at entry

    # 1. Restore config from snapshot (niri auto-reloads on file change)
    cp "$BACKUP" "$CONFIG"

    # 2. Restore column widths on all workspaces
    resize_all_columns "76.666667%"

    rm -f "$STATE_FILE" "$BACKUP"
else
    # ENTERING TILE MODE

    # 1. Snapshot config, then apply tile-mode values
    #    Patterns match any current value so the script never needs updating
    #    when you edit the default config.
    cp "$CONFIG" "$BACKUP"
    sed -i --follow-symlinks 's/center-focused-column "[^"]*"/center-focused-column "never"/' "$CONFIG"
    sed -i --follow-symlinks 's/^\(\s*\)gaps [0-9]\+/\1gaps 2/' "$CONFIG"
    sed -i --follow-symlinks 's/width [0-9]\+ \/\/ 1 current/width 0 \/\/ 1 current/' "$CONFIG"
    sed -i --follow-symlinks 's/width [0-9]\+ \/\/ 3 current/width 2 \/\/ 3 current/' "$CONFIG"
    sed -i --follow-symlinks 's/^\(\s*\)opacity [0-9.]*/\1opacity 1.0/' "$CONFIG"
    sed -i --follow-symlinks 's/default-column-width { proportion 0\.[0-9]\+; }/default-column-width { proportion 0.5; }/' "$CONFIG"

    # 2. Set ALL columns on ALL workspaces to 50%
    resize_all_columns "50%"

    touch "$STATE_FILE"
fi
