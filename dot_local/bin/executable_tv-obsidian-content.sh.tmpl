#!/usr/bin/env bash
RG=/home/linuxbrew/.linuxbrew/bin/rg
VAULT_DIR="{{ .obsidian.vault_path }}"
VAULT_NAME="{{ .obsidian.vault_name }}"

echo -n "Search content: "
read -r query
[ -z "$query" ] && exit 0

output=$(
    $RG -l --glob "*.md" "$query" "$VAULT_DIR" |
    awk -v vault_dir="$VAULT_DIR/" '{
      path = $0;
      sub(vault_dir, "", path); # Remove absolute path prefix
      
      match(path, /.*\//);
      if (RLENGTH > 0) {
        dir = substr(path, 1, RLENGTH);
        file = substr(path, RLENGTH+1);
        
        first_slash = index(dir, "/");
        parent = substr(dir, 1, first_slash);
        rest_dir = substr(dir, first_slash + 1);
        
        printf "\033[38;2;208;167;175m%s\033[36m%s\033[0m%s\n", parent, rest_dir, file;
      } else {
        printf "\033[0m%s\n", path;
      }
    }' |
    tv --source-command="cat" \
       --ansi \
       --source-output="{strip_ansi}" \
       --preview-command="$RG --color=always -C2 '$query' \"$VAULT_DIR/{strip_ansi}\"" \
       --preview-size=60 \
       --preview-word-wrap \
       --preview-border=thick \
       --input-header="Results: $query" \
       --layout=portrait \
       --expect="ctrl-p;ctrl-c"
)

[ -z "$output" ] && exit 0

key=$(echo "$output" | head -n 1)
selected=$(echo "$output" | tail -n +2)

if [ "$key" = "ctrl-p" ]; then
    printf "%s/%s" "$VAULT_DIR" "$selected" | wl-copy
    exit 0
elif [ "$key" = "ctrl-c" ]; then
    printf "%s" "$selected" | wl-copy
    exit 0
fi

if obsidian files total >/dev/null 2>&1; then
    obsidian open "path=$selected" newtab
else
    echo "$selected" > /tmp/tv-obsidian-pending
    niri msg action spawn -- {{ .chezmoi.homeDir }}/.local/bin/tv-obsidian-launcher.sh
fi
