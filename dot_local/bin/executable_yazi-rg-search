#!/usr/bin/env bash
RG=/home/linuxbrew/.linuxbrew/bin/rg

echo -n "Search content: "
read -r query
[ -z "$query" ] && exit 0

selected=$($RG -l "$query" "$PWD" |
    sed "s|$PWD/||" |
    fzf --preview "$RG --color=always -C2 '$query' \"$PWD\"/{}" \
        --preview-window=right:60%:wrap)

[ -z "$selected" ] && exit 0

ya emit-to "$YAZI_ID" reveal --str "$PWD/$selected"
