#!/usr/bin/python3
"""
niri-minimap: A live symbolic spatial minimap overlay for Niri.

Shows workspaces stacked vertically with windows represented by their app icons,
arranged according to their column/tile positions. The focused window gets a
highlight border that updates in real time as you change focus.

Toggle on/off with the same keybind. Does NOT steal keyboard focus, so you can
use Mod+WASD to navigate while the minimap is visible.

See # --- Configuration --- for aesthetic options.

Must pkill -f niri-minimap for changes to take hold.
"""

import ctypes.util
import json
import os
import signal
import subprocess
import sys
import threading
from collections import defaultdict

# --- Toggle: kill existing instance if running ---
PID_FILE = os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "niri-minimap.pid")


def _is_minimap_pid(pid):
    """Return True only if pid belongs to a niri-minimap process."""
    try:
        cmdline = open(f"/proc/{pid}/cmdline").read()
        return "niri-minimap" in cmdline
    except OSError:
        return False


def check_toggle():
    """If another instance is running, signal it based on args and exit. Otherwise write our PID."""
    if os.path.exists(PID_FILE):
        try:
            with open(PID_FILE) as f:
                old_pid = int(f.read().strip())
            os.kill(old_pid, 0)

            if not _is_minimap_pid(old_pid):
                # Stale PID reused by an unrelated process — ignore and start fresh
                raise ProcessLookupError

            # Decide what signal to send
            sig = signal.SIGUSR1  # default: toggle
            if len(sys.argv) > 1:
                if sys.argv[1] == "show":
                    sig = signal.SIGUSR2
                elif sys.argv[1] == "hide":
                    sig = signal.SIGHUP

            os.kill(old_pid, sig)
            sys.exit(0)
        except (ProcessLookupError, ValueError):
            pass
        except PermissionError:
            pass

    with open(PID_FILE, "w") as f:
        f.write(str(os.getpid()))


def cleanup_pid():
    try:
        os.remove(PID_FILE)
    except FileNotFoundError:
        pass


# --- Toggle check FIRST (so toggle-off is near-instant, no extra work) ---
# Only run on the first exec (before LD_PRELOAD re-exec), since execvp
# preserves PID and we'd find our own PID in the file.
_LAYER_SO = ctypes.util.find_library("gtk4-layer-shell")
if not _LAYER_SO:
    # Fallback paths for systems where find_library fails
    for p in ["/usr/lib64/libgtk4-layer-shell.so.0", "/usr/lib/libgtk4-layer-shell.so"]:
        if os.path.exists(p):
            _LAYER_SO = p
            break

if _LAYER_SO and _LAYER_SO not in os.environ.get("LD_PRELOAD", ""):
    check_toggle()
    os.environ["LD_PRELOAD"] = _LAYER_SO
    os.execvp(sys.executable, [sys.executable] + sys.argv)

signal.signal(signal.SIGTERM, lambda *_: (cleanup_pid(), sys.exit(0)))

# --- Early parallel work: start event stream + desktop scan BEFORE GTK loads ---
# These run concurrently with the ~80ms GTK import below.
_early_event_proc = subprocess.Popen(
    ["niri", "msg", "--json", "event-stream"],
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
)


def _scan_desktop_icons():
    dirs = [
        os.path.expanduser("~/.local/share/applications"),
        "/usr/share/applications",
        "/var/lib/flatpak/exports/share/applications",
    ]
    flatpak_user = os.path.expanduser("~/.var/app")
    if os.path.isdir(flatpak_user):
        for app in os.listdir(flatpak_user):
            candidate = os.path.join(flatpak_user, app, "export/share/applications")
            if os.path.isdir(candidate):
                dirs.append(candidate)
    icon_map = {}
    for d in dirs:
        if not os.path.isdir(d):
            continue
        for fname in os.listdir(d):
            if not fname.endswith(".desktop"):
                continue
            app_id = fname[:-8]
            if app_id in icon_map:
                continue
            path = os.path.join(d, fname)
            try:
                with open(path) as fh:
                    for line in fh:
                        if line.startswith("Icon="):
                            icon_map[app_id] = line[5:].strip()
                            break
            except OSError:
                pass
    return icon_map


_desktop_scan_thread = threading.Thread(target=lambda: None, daemon=True)
_desktop_icon_result = [None]


def _scan_worker():
    _desktop_icon_result[0] = _scan_desktop_icons()


_desktop_scan_thread = threading.Thread(target=_scan_worker, daemon=True)
_desktop_scan_thread.start()

# gtk4-layer-shell must be loaded before libwayland.
import gi

gi.require_version("Gdk", "4.0")
gi.require_version("Gtk", "4.0")
gi.require_version("Gtk4LayerShell", "1.0")
from gi.repository import Gdk, GLib, Gtk, Gtk4LayerShell

# --- Configuration ---
# Layout
MINIMAP_WIDTH = (
    0.55  # default width as a fraction of monitor width (expands if content needs more)
)
ICON_SIZE = 43  # px, app icon size, 48
CELL_PAD = 0  # px, outer margin around each tile (space outside the ring)
TILE_PAD = 3  # px, inner padding between icon and the ring
COL_SPACING = 16  # px, horizontal gap between columns
TILE_SPACING = 11  # px, vertical gap between tiles in a column
WS_SPACING = 15  # px, vertical gap between workspaces

# Borders & radii
BORDER_WIDTH = 7  # px, highlight ring around focused/active tiles
OUTER_BORDER_WIDTH = 1  # px, border around the whole minimap panel
OUTER_BORDER_RADIUS = 9  # px, corner rounding of the outer panel
TILE_BORDER_RADIUS = 5  # px, corner rounding of tiles and columns (focused workspace)
UNFOCUSED_TILE_RADIUS = "50%"  # border-radius for tiles/columns in non-focused workspaces (50% = circle, ~35% = squircle)
UNFOCUSED_TILE_PAD = TILE_PAD + 4  # extra padding for circular tiles so the icon clears the circle boundary
FOCUS_RING_CIRCLE = (
    False  # True = circle focus ring (border-radius 50%), False = rounded square
)

# Colors: ("#RRGGBB", alpha) — alpha is 0.0 (transparent) to 1.0 (opaque)
FOCUS_RING_COLOR = ("#00B6C2", 1.00)  # focused window border ring (theme gold)
FOCUS_FILL_COLOR = ("#D0A7AF", 1.00)  # focused window background fill (turquoise)
INACTIVE_FILL_COLOR = ("#7A2E2E", 1.00)  # non-focused window fill (terracotta)
NORMAL_COLOR = ("#595966", 1.00)  # reserved / unused
BG_COLOR = ("#000000", 1.00)  # outer panel background, old #1F1F26
WS_BG_COLOR = ("#2E2E38", 1.00)  # workspace background
OUTER_BORDER_COLOR = ("#574150", 1.00)  # outer panel border
COLUMN_COLOR = ("#7A2E2E", 1.00)  # non-spine column background (terracotta)
SPINE_COLOR = ("#7A2E2E", 1.00)  # spine column background (terracotta)
WS_RING_COLOR = ("#D0A7AF", 1.00)  # focused-workspace ring (turquoise)
SPINE_LINE_COLOR = ("#FFA726", 1.00)  # faint vertical accent through the spine column

# Timing
FADE_MS = 50  # fade-in/out duration in ms (quick to stay unobtrusive)
FADE_STEP_MS = 8  # animation tick interval (~120fps target, GTK caps to vsync)
HOVER_DELAY_MS = 120  # delay before showing hover label, so fast sweeps don't flash it
SPINE_LINE_WIDTH = 2  # px, vertical accent line width


def _c(color):
    """Convert a ("#RRGGBB", alpha) color tuple to a CSS rgb()/rgba() string."""
    hex_str, alpha = color
    h = hex_str.lstrip("#")
    r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
    if alpha >= 1.0:
        return f"rgb({r}, {g}, {b})"
    return f"rgba({r}, {g}, {b}, {alpha})"


# --- .desktop icon cache (pre-scanned in background thread above) ---


def get_desktop_icon_map():
    _desktop_scan_thread.join()  # blocks only if scan isn't done yet (~9ms)
    return _desktop_icon_result[0]


def lookup_icon_name(app_id, icon_theme):
    """Look up icon for an app_id, consulting .desktop files first."""
    if not app_id:
        return "application-x-executable"

    desktop_map = get_desktop_icon_map()

    # Check .desktop file for this app_id
    if app_id in desktop_map:
        icon = desktop_map[app_id]
        if os.path.isabs(icon):
            # Absolute path — use it directly (handled by Gtk.Image.new_from_file)
            return icon
        if icon_theme.has_icon(icon):
            return icon

    # Fallback: try app_id directly as icon name
    if icon_theme.has_icon(app_id):
        return app_id
    lower = app_id.lower()
    if icon_theme.has_icon(lower):
        return lower
    if "." in app_id:
        short = app_id.rsplit(".", 1)[-1].lower()
        if icon_theme.has_icon(short):
            return short

    return "application-x-executable"


def parse_state(workspaces_raw, windows_raw):
    """Build structured workspace model from raw JSON data."""
    ws_by_id = {}
    for ws in workspaces_raw:
        ws_by_id[ws["id"]] = {
            "id": ws["id"],
            "idx": ws["idx"],
            "name": ws.get("name"),
            "is_focused": ws["is_focused"],
            "is_active": ws["is_active"],
            "active_window_id": ws.get("active_window_id"),
            "columns": defaultdict(list),
        }

    # Index windows by id for active-window lookups
    win_by_id = {}
    for win in windows_raw:
        win_by_id[win["id"]] = win
        ws_id = win.get("workspace_id")
        if ws_id is None or ws_id not in ws_by_id:
            continue
        pos = win["layout"].get("pos_in_scrolling_layout")
        if pos is None:
            continue
        col_idx, tile_idx = pos
        ws_by_id[ws_id]["columns"][col_idx].append(
            {
                "id": win["id"],
                "app_id": win.get("app_id", ""),
                "title": win.get("title", ""),
                "is_focused": win["is_focused"],
                "col_idx": col_idx,
                "tile_idx": tile_idx,
            }
        )

    for ws in ws_by_id.values():
        for col_idx in ws["columns"]:
            ws["columns"][col_idx].sort(key=lambda w: w["tile_idx"])

    # Compute each workspace's active column position (0-based index among
    # its sorted columns). This is the column that Niri will focus when you
    # switch to that workspace.
    for ws in ws_by_id.values():
        active_col_pos = 0  # default: leftmost
        awid = ws["active_window_id"]
        if awid and awid in win_by_id:
            pos = win_by_id[awid]["layout"].get("pos_in_scrolling_layout")
            if pos:
                target_col_idx = pos[0]
                sorted_col_indices = sorted(ws["columns"].keys())
                if target_col_idx in sorted_col_indices:
                    active_col_pos = sorted_col_indices.index(target_col_idx)
        ws["active_col_pos"] = active_col_pos

    result = sorted(ws_by_id.values(), key=lambda w: w["idx"])
    result = [ws for ws in result if ws["columns"]]
    return result


class MinimapWindow(Gtk.Window):
    def __init__(self, app):
        super().__init__(application=app)
        self.icon_theme = Gtk.IconTheme.get_for_display(Gdk.Display.get_default())

        self.tile_widgets = {}  # win_id -> Gtk.Box
        self._hovered_win_id = None
        self._designated_win_ids = set()
        self._request_rebuild = None  # set by app after construction
        self._fade_timer_id = None
        self._hover_pending_id = None
        self._hover_hide_id = None
        self._pending_hover_title = ""

        Gtk4LayerShell.init_for_window(self)
        Gtk4LayerShell.set_layer(self, Gtk4LayerShell.Layer.OVERLAY)
        Gtk4LayerShell.set_keyboard_mode(self, Gtk4LayerShell.KeyboardMode.NONE)
        Gtk4LayerShell.set_namespace(self, "niri-minimap")

        self.set_decorated(False)

        self.outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.outer.set_halign(Gtk.Align.CENTER)
        self.outer.set_valign(Gtk.Align.CENTER)
        self.outer.add_css_class("minimap-outer")

        display = Gdk.Display.get_default()
        monitors = display.get_monitors()
        if monitors and monitors.get_n_items() > 0:
            monitor = monitors.get_item(0)
            geometry = monitor.get_geometry()
            min_width = int(geometry.width * MINIMAP_WIDTH)
            self.outer.set_size_request(min_width, -1)

        self.frame = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=WS_SPACING)
        # Generous transparent margins around the visible content. These expand
        # the overlay's bounds so the hover tooltip can spawn anywhere within
        # them without being clipped — no flipping needed. Equal top/bottom
        # keeps the visible panel centered on screen.
        self.frame.set_margin_top(120)
        self.frame.set_margin_bottom(120)
        self.frame.set_margin_start(120)
        self.frame.set_margin_end(120)
        self.outer.append(self.frame)

        # Wrap outer in an Overlay so the hover label can float over content
        self._overlay_wrapper = Gtk.Overlay()
        self._overlay_wrapper.set_child(self.outer)

        self._hover_label = Gtk.Label()
        self._hover_label.set_visible(False)
        self._hover_label.set_halign(Gtk.Align.START)
        self._hover_label.set_valign(Gtk.Align.START)
        self._hover_label.set_can_target(False)  # never intercept pointer events
        self._hover_label.add_css_class("minimap-hover-label")
        self._overlay_wrapper.add_overlay(self._hover_label)

        self.set_child(self._overlay_wrapper)

        # Motion tracker on the wrapper: update label position and hide on leave
        motion_tracker = Gtk.EventControllerMotion.new()
        motion_tracker.connect("motion", self._on_outer_motion)
        motion_tracker.connect("leave", lambda _c: self._cancel_hover_label())
        self._overlay_wrapper.add_controller(motion_tracker)

        # Click handlers are attached per-tile in rebuild(); no outer-level
        # click handler — clicks in the gaps between tiles must do nothing.

    def rebuild(self, workspaces):
        """Tear down and rebuild all widgets from fresh state."""
        self.tile_widgets.clear()
        
        try:
            tag_file = os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "niri-tags.json")
            with open(tag_file) as f:
                numbered_tags_map = {v: str(k) for k, v in json.load(f).items()}
        except Exception:
            numbered_tags_map = {}

        while True:
            child = self.frame.get_first_child()
            if child is None:
                break
            self.frame.remove(child)

        if not workspaces:
            return

        # Prune designation set to only live window IDs
        live_ids = {
            t["id"]
            for ws in workspaces
            for col in ws["columns"].values()
            for t in col
        }
        self._designated_win_ids.intersection_update(live_ids)

        # To keep the "spine" (active column) at a fixed screen position,
        # we build a symmetrical grid where the spine is always at the center.
        # This way, when the grid is centered on screen, the spine stays put
        # even if one workspace's focus shifts or content grows.

        # l_max: max columns to the left of the spine
        # r_max: max columns to the right of the spine
        l_max = 0
        r_max = 0
        for ws in workspaces:
            acp = ws["active_col_pos"]
            n_cols = len(ws["columns"])
            l_max = max(l_max, acp)
            r_max = max(r_max, n_cols - 1 - acp)

        # M is the distance from the spine to the edge of the symmetrical grid
        m = max(l_max, r_max)
        grid_width = 2 * m + 1
        spine_index = m

        grid = Gtk.Grid()
        grid.set_halign(Gtk.Align.CENTER)
        grid.set_valign(Gtk.Align.CENTER)
        grid.set_column_spacing(COL_SPACING)
        grid.set_row_spacing(0)
        # Homogeneous columns ensure the grid center aligns with the spine
        grid.set_column_homogeneous(True)

        grid_row = 0
        for ws_i, ws in enumerate(workspaces):
            if ws_i > 0:
                spacer = Gtk.Box()
                spacer.set_size_request(1, WS_SPACING)
                grid.attach(spacer, 0, grid_row, grid_width, 1)
                grid_row += 1

            # Offset so the active column is at spine_index
            acp = ws["active_col_pos"]
            start_col = spine_index - acp

            for i, (col_idx, tiles) in enumerate(sorted(ws["columns"].items())):
                col_box = Gtk.Box(
                    orientation=Gtk.Orientation.VERTICAL,
                    spacing=TILE_SPACING,
                )
                col_box.set_valign(Gtk.Align.CENTER)
                if ws["is_focused"]:
                    if start_col + i == spine_index:
                        col_box.add_css_class("minimap-spine-column")
                    else:
                        col_box.add_css_class("minimap-column")
                else:
                    if start_col + i == spine_index:
                        col_box.add_css_class("minimap-spine-column-unfocused")
                    else:
                        col_box.add_css_class("minimap-column-unfocused")

                # Scale down icons for stacked columns so they don't dominate height
                n_tiles = len(tiles)
                if n_tiles > 1:
                    col_box.add_css_class("minimap-col-stacked")
                if n_tiles == 1:
                    tile_icon_size = ICON_SIZE
                elif n_tiles == 2:
                    # Size n=2 so total column height == single-tile height:
                    # 2*(icon + 2*stacked_border) + TILE_SPACING = ICON_SIZE + 2*TILE_PAD + 2*BORDER_WIDTH
                    _single_h = ICON_SIZE + 2 * TILE_PAD + 2 * BORDER_WIDTH
                    tile_icon_size = max(12, (_single_h - TILE_SPACING) // 2 - 4)
                else:
                    tile_icon_size = max(12, int(ICON_SIZE * 0.46))

                for tile in tiles:
                    designated = tile["id"] in self._designated_win_ids
                    num_tag = numbered_tags_map.get(tile["id"])
                    has_overlay = designated or num_tag is not None

                    # Use Overlay as tile container when we need to layer indicators
                    # on top; plain Box otherwise.
                    if has_overlay:
                        tile_box = Gtk.Overlay()
                        tile_box.set_overflow(Gtk.Overflow.VISIBLE)
                    else:
                        tile_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
                    tile_box.set_halign(Gtk.Align.FILL if n_tiles > 1 else Gtk.Align.CENTER)
                    tile_box.set_valign(Gtk.Align.CENTER)
                    tile_box.set_margin_top(CELL_PAD)
                    tile_box.set_margin_bottom(CELL_PAD)
                    tile_box.set_margin_start(CELL_PAD)
                    tile_box.set_margin_end(CELL_PAD)
                    if n_tiles > 1:
                        tile_box.add_css_class("minimap-stacked")

                    icon_name = lookup_icon_name(tile["app_id"], self.icon_theme)
                    if os.path.isabs(icon_name):
                        icon = Gtk.Image.new_from_file(icon_name)
                    else:
                        icon = Gtk.Image.new_from_icon_name(icon_name)
                    icon.set_pixel_size(tile_icon_size)
                    icon.set_halign(Gtk.Align.CENTER)
                    if n_tiles > 1:
                        icon.set_hexpand(True)

                    in_spine = start_col + i == spine_index
                    if tile["is_focused"]:
                        tile_box.add_css_class("minimap-tile-focused")
                    else:
                        if ws["is_focused"]:
                            tile_box.add_css_class("minimap-tile-workspace")
                        elif in_spine:
                            tile_box.add_css_class("minimap-tile-spine")
                        else:
                            tile_box.add_css_class("minimap-tile")

                    if has_overlay:
                        tile_box.set_child(icon)
                        tri = Gtk.DrawingArea()
                        dot_size = max(16, ICON_SIZE // 2) if num_tag else max(10, ICON_SIZE // 3)
                        tri.set_size_request(dot_size, dot_size)
                        tri.set_halign(Gtk.Align.END)
                        tri.set_valign(Gtk.Align.CENTER)
                        tri.set_margin_end(-(dot_size // 2 + 9))
                        tri.set_can_target(False)
                        _r = dot_size / 2
                        
                        def _draw_tag(da, cr, w, h, r=_r, txt=num_tag):
                            cr.arc(w / 2, h / 2, r, 0, 6.283185)
                            cr.set_source_rgb(1.0, 0.655, 0.149)
                            cr.fill_preserve()
                            cr.set_source_rgb(0, 0, 0)
                            cr.set_line_width(1)
                            cr.stroke()
                            if txt:
                                cr.set_source_rgb(0, 0, 0)
                                cr.select_font_face("sans-serif", 0, 1) # normal, bold
                                cr.set_font_size(r * 1.6)
                                extents = cr.text_extents(txt)
                                ascent, descent, height, max_x_adv, max_y_adv = cr.font_extents()
                                
                                # Use font ascent/descent for stable vertical centering
                                x = w / 2 - (extents.width / 2 + extents.x_bearing)
                                y = h / 2 + (ascent - descent) / 2
                                cr.move_to(x, y)
                                cr.show_text(txt)
                                
                        tri.set_draw_func(_draw_tag)
                        tile_box.add_overlay(tri)
                    else:
                        tile_box.append(icon)

                    motion = Gtk.EventControllerMotion.new()
                    win_id = tile["id"]
                    title_text = tile["title"] or tile["app_id"]
                    motion.connect(
                        "enter",
                        lambda _c, _x, _y, wid=win_id, t=title_text: self._on_tile_hover(wid, t),
                    )
                    motion.connect("leave", lambda _c: self._on_tile_unhover())
                    tile_box.add_controller(motion)

                    # Per-tile click handler. Hits only when the pointer is
                    # truly inside this tile's allocation — gap clicks have
                    # no handler and harmlessly fall through.
                    click = Gtk.GestureClick.new()
                    click.set_button(0)  # 0 = any button
                    click.connect(
                        "pressed",
                        lambda g, _n, _x, _y, wid=win_id: self._on_tile_click(g, wid),
                    )
                    tile_box.add_controller(click)

                    col_box.append(tile_box)
                    self.tile_widgets[tile["id"]] = (tile_box, in_spine, ws["id"])

                grid.attach(col_box, start_col + i, grid_row, 1, 1)

            grid_row += 1

        # Add a dummy spacer to the first and last columns to ensure symmetry
        # even if no workspace uses those columns.
        if grid_width > 0:
            for c in [0, grid_width - 1]:
                spacer = Gtk.Box()
                # 47 is the calculated width of a tile column (ICON_SIZE+2*CELL_PAD+2*BORDER_WIDTH+2*padding)
                spacer.set_size_request(51, 1)
                grid.attach(spacer, c, grid_row, 1, 1)

        # Wrap grid in an Overlay so the spine line can paint on TOP of tile
        # faces, giving a continuous vertical accent from top to bottom.
        # halign=CENTER aligns the line with the grid's center column, which
        # is the spine column (by construction: spine_index = m, grid_width =
        # 2m+1, column_homogeneous=True).
        grid_overlay = Gtk.Overlay()
        grid_overlay.set_child(grid)
        grid_overlay.set_overflow(Gtk.Overflow.VISIBLE)
        spine_line = Gtk.Box()
        spine_line.set_size_request(SPINE_LINE_WIDTH, -1)
        spine_line.set_halign(Gtk.Align.CENTER)
        spine_line.set_valign(Gtk.Align.FILL)
        spine_line.set_margin_top(-WS_SPACING)
        spine_line.set_margin_bottom(-WS_SPACING)
        spine_line.add_css_class("minimap-spine-line")
        spine_line.set_can_target(False)  # don't intercept clicks meant for tiles
        grid_overlay.add_overlay(spine_line)

        self.frame.append(grid_overlay)

    def _on_tile_hover(self, win_id, title):
        # Cancel any pending hide — we're back on a tile.
        if self._hover_hide_id is not None:
            GLib.source_remove(self._hover_hide_id)
            self._hover_hide_id = None
        self._hovered_win_id = win_id
        # If label is already visible, swap text instantly (no extra delay for
        # tile-to-tile scanning). Otherwise wait HOVER_DELAY_MS before showing
        # so quick pointer sweeps don't trigger a flicker of labels.
        if self._hover_label.get_visible():
            self._hover_label.set_text(title)
            return
        if self._hover_pending_id is not None:
            GLib.source_remove(self._hover_pending_id)
        self._pending_hover_title = title
        self._hover_pending_id = GLib.timeout_add(HOVER_DELAY_MS, self._show_hover_label)

    def _on_tile_unhover(self):
        # Cancel a pending show — pointer left before delay elapsed.
        if self._hover_pending_id is not None:
            GLib.source_remove(self._hover_pending_id)
            self._hover_pending_id = None
        # Schedule a hide with a brief grace period; if pointer lands on an
        # adjacent tile within that window, _on_tile_hover cancels it.
        if self._hover_hide_id is not None:
            GLib.source_remove(self._hover_hide_id)
        self._hover_hide_id = GLib.timeout_add(40, self._do_hide_hover_label)

    def _show_hover_label(self):
        self._hover_pending_id = None
        self._hover_label.set_text(self._pending_hover_title)
        self._hover_label.set_visible(True)
        return False

    def _do_hide_hover_label(self):
        self._hover_hide_id = None
        self._hover_label.set_visible(False)
        return False

    def _cancel_hover_label(self):
        if self._hover_pending_id is not None:
            GLib.source_remove(self._hover_pending_id)
            self._hover_pending_id = None
        if self._hover_hide_id is not None:
            GLib.source_remove(self._hover_hide_id)
            self._hover_hide_id = None
        self._hover_label.set_visible(False)

    def _on_outer_motion(self, ctrl, x, y):
        # Always place label below+right of cursor. The frame has generous
        # transparent margins, so labels near the visible bottom edge of the
        # panel still spawn inside the overlay's bounds — no teleporting.
        GAP = 18
        self._hover_label.set_margin_start(int(x) + GAP)
        self._hover_label.set_margin_top(int(y) + GAP)

    def _focus_window(self, win_id):
        threading.Thread(
            target=lambda: subprocess.run(
                ["niri", "msg", "action", "focus-window", "--id", str(win_id)],
                capture_output=True,
            ),
            daemon=True,
        ).start()

    def _on_tile_click(self, gesture, win_id):
        if gesture.get_current_button() == 3:
            # Right-click: toggle designation
            if win_id in self._designated_win_ids:
                self._designated_win_ids.discard(win_id)
            else:
                self._designated_win_ids.add(win_id)
            if self._request_rebuild:
                self._request_rebuild()
        else:
            # Left-click: focus window and close minimap
            self._focus_window(win_id)
            self.fade_out()

    def fade_in(self):
        """Present the window if hidden and animate opacity 0->1."""
        if self._fade_timer_id is not None:
            GLib.source_remove(self._fade_timer_id)
            self._fade_timer_id = None
        if not self.get_visible():
            self._overlay_wrapper.set_opacity(0.0)
            self.present()
        self._animate_opacity(1.0, on_done=None)

    def fade_out(self):
        """Animate opacity to 0, then hide the window."""
        if not self.get_visible():
            return
        if self._fade_timer_id is not None:
            GLib.source_remove(self._fade_timer_id)
            self._fade_timer_id = None
        self._animate_opacity(0.0, on_done=self._after_fade_out)

    def _after_fade_out(self):
        self.set_visible(False)
        self._cancel_hover_label()

    def _animate_opacity(self, target, on_done):
        start_op = self._overlay_wrapper.get_opacity()
        start_t = GLib.get_monotonic_time()
        if abs(target - start_op) < 0.001:
            if on_done:
                on_done()
            return

        def step():
            elapsed_ms = (GLib.get_monotonic_time() - start_t) / 1000.0
            t = min(1.0, elapsed_ms / FADE_MS)
            eased = 1.0 - (1.0 - t) * (1.0 - t)  # ease-out quad
            self._overlay_wrapper.set_opacity(start_op + (target - start_op) * eased)
            if t >= 1.0:
                self._fade_timer_id = None
                if on_done:
                    on_done()
                return False
            return True

        self._fade_timer_id = GLib.timeout_add(FADE_STEP_MS, step)

    def update_focus(self, focused_window_id, focused_ws_id):
        """Update CSS classes to reflect the newly focused window/workspace."""
        for win_id, (tile_box, in_spine, ws_id) in self.tile_widgets.items():
            tile_box.remove_css_class("minimap-tile")
            tile_box.remove_css_class("minimap-tile-spine")
            tile_box.remove_css_class("minimap-tile-workspace")
            tile_box.remove_css_class("minimap-tile-focused")

            if win_id == focused_window_id:
                tile_box.add_css_class("minimap-tile-focused")
            else:
                if ws_id == focused_ws_id:
                    tile_box.add_css_class("minimap-tile-workspace")
                elif in_spine:
                    tile_box.add_css_class("minimap-tile-spine")
                else:
                    tile_box.add_css_class("minimap-tile")


class EventStreamReader:
    """Reads niri event-stream in a background thread and dispatches to GTK."""

    def __init__(self, callback):
        self.callback = callback
        self._proc = None
        self._thread = None

    def start(self):
        global _early_event_proc
        # Reuse the process started at module load (saves ~60ms)
        self._proc = _early_event_proc
        _early_event_proc = None
        self._thread = threading.Thread(target=self._read_loop, daemon=True)
        self._thread.start()

    def stop(self):
        if self._proc:
            self._proc.terminate()
            self._proc = None

    def _read_loop(self):
        for line in self._proc.stdout:
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue
            GLib.idle_add(self.callback, event)


class MinimapApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="dev.niri.minimap")
        self._win = None
        self._event_reader = None
        self._windows = {}
        self._workspaces = {}
        self._focused_window_id = None
        self._focused_ws_id = None
        self._got_initial_windows = False
        self._got_initial_workspaces = False
        self._autohide_timer_id = None
        self._rebuild_pending = False

    def do_activate(self):
        self.hold()  # Keep app running even if the window is hidden

        css_provider = Gtk.CssProvider()
        css_provider.load_from_string(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        self._win = MinimapWindow(self)
        self._win.set_hide_on_close(True)
        self._win._request_rebuild = self._full_rebuild

        GLib.unix_signal_add(
            GLib.PRIORITY_DEFAULT, signal.SIGUSR1, self._on_toggle_signal
        )
        GLib.unix_signal_add(
            GLib.PRIORITY_DEFAULT, signal.SIGUSR2, self._on_show_signal
        )
        GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGHUP, self._on_hide_signal)
        # GLib.unix_signal_add doesn't support real-time signals; Python's default
        # action for SIGRTMIN is to terminate, so install a Python-level handler
        # that hands the work back to the GLib main loop. The idle callback must
        # return False or it will be re-run every idle tick, starving input events.
        def _sigrtmin_idle():
            self._full_rebuild()
            return False
        signal.signal(
            signal.SIGRTMIN,
            lambda *_: GLib.idle_add(_sigrtmin_idle),
        )

        # Start event stream — initial dump provides both windows and workspaces
        self._event_reader = EventStreamReader(callback=self._on_event)
        self._event_reader.start()

        self._win.fade_in()

    def _on_tags_changed_signal(self):
        self._full_rebuild()
        return True

    def _on_toggle_signal(self):
        if self._win:
            if self._win.get_visible():
                self._win.fade_out()
            else:
                self._win.fade_in()
        return True

    def _on_show_signal(self):
        # SIGUSR2 = "nudge": show minimap if hidden, or reset autohide timer if visible.
        # Used by WASD navigation keys — opens on first keypress and auto-closes after timer.
        if self._win:
            self._win.fade_in()
            self._reset_autohide_timer()
        return True

    def _on_hide_signal(self):
        if self._win and self._win.get_visible():
            self._win.fade_out()
        return True

    def _reset_autohide_timer(self):
        if self._autohide_timer_id is not None:
            GLib.source_remove(self._autohide_timer_id)
        tile_mode = os.path.exists(os.path.expanduser("~/.cache/niri-tile-toggle"))
        delay = 350 if tile_mode else 550
        self._autohide_timer_id = GLib.timeout_add(delay, self._autohide_cb)

    def _autohide_cb(self):
        self._autohide_timer_id = None
        if self._win and self._win.get_visible():
            self._win.fade_out()
        return False

    def do_shutdown(self):
        if self._event_reader:
            self._event_reader.stop()
        cleanup_pid()
        Gtk.Application.do_shutdown(self)

    def _full_rebuild(self):
        # Coalesce bursts of events into one rebuild per idle cycle.
        # Without this, fast Mod+Ctrl+WASD presses queue multiple full
        # rebuilds and the main thread can't keep up, causing visible skips.
        if self._rebuild_pending:
            return
        self._rebuild_pending = True
        GLib.idle_add(self._do_rebuild, priority=GLib.PRIORITY_HIGH_IDLE)

    def _do_rebuild(self):
        self._rebuild_pending = False
        ws_list = parse_state(
            list(self._workspaces.values()),
            list(self._windows.values()),
        )
        self._win.rebuild(ws_list)
        return False

    def _try_initial_build(self):
        """Build UI once we have both initial dumps."""
        if self._got_initial_windows and self._got_initial_workspaces:
            self._full_rebuild()

    def _on_event(self, event):
        if "WindowsChanged" in event:
            self._windows = {w["id"]: w for w in event["WindowsChanged"]["windows"]}
            self._sync_focus_from_windows()
            self._got_initial_windows = True
            self._try_initial_build()

        elif "WorkspacesChanged" in event:
            self._workspaces = {
                ws["id"]: ws for ws in event["WorkspacesChanged"]["workspaces"]
            }
            self._sync_ws_focus()
            self._got_initial_workspaces = True
            self._try_initial_build()

        elif "WindowFocusChanged" in event:
            new_id = event["WindowFocusChanged"].get("id")
            # Update is_focused on every window record — niri only tells us the
            # new focused id, not which window lost focus. Without this, the
            # old focused window stays is_focused=True and gets the gold ring
            # alongside its workspace's spine ring.
            for w in self._windows.values():
                w["is_focused"] = w["id"] == new_id
            self._focused_window_id = new_id
            if new_id and new_id in self._windows:
                self._focused_ws_id = self._windows[new_id].get("workspace_id")
            self._full_rebuild()

        elif "WindowOpenedOrChanged" in event:
            win = event["WindowOpenedOrChanged"]["window"]
            self._windows[win["id"]] = win
            if win.get("is_focused"):
                # Same as WindowFocusChanged: unmark stale focus on other windows
                for w in self._windows.values():
                    if w["id"] != win["id"]:
                        w["is_focused"] = False
                self._focused_window_id = win["id"]
                self._focused_ws_id = win.get("workspace_id")
            self._full_rebuild()

        elif "WindowClosed" in event:
            wid = event["WindowClosed"]["id"]
            self._windows.pop(wid, None)
            if self._focused_window_id == wid:
                self._focused_window_id = None
            self._full_rebuild()

        elif "WorkspaceActivated" in event:
            ws_id = event["WorkspaceActivated"]["id"]
            focused = event["WorkspaceActivated"].get("focused", False)
            # Update is_focused/is_active flags on workspace records — parse_state()
            # reads these directly to decide focused-workspace styling (squares vs
            # circles). Without this, switching workspaces leaves the old workspace
            # styled as focused until the next full state refresh.
            target = self._workspaces.get(ws_id)
            if target is not None:
                same_output = target.get("output")
                for ws in self._workspaces.values():
                    if ws.get("output") == same_output:
                        ws["is_active"] = ws["id"] == ws_id
                if focused:
                    for ws in self._workspaces.values():
                        ws["is_focused"] = ws["id"] == ws_id
            if focused:
                self._focused_ws_id = ws_id
            # Focused workspace changed — needs a rebuild, not just update_focus
            self._full_rebuild()

        elif "WorkspaceActiveWindowChanged" in event:
            ws_id = event["WorkspaceActiveWindowChanged"]["workspace_id"]
            awid = event["WorkspaceActiveWindowChanged"].get("active_window_id")
            if ws_id in self._workspaces:
                self._workspaces[ws_id]["active_window_id"] = awid
            # Active column may have changed — rebuild to update alignment
            self._full_rebuild()

        elif "WindowLayoutsChanged" in event:
            # Fires when column/tile positions change (e.g. Mod+Ctrl+WASD moves,
            # consume/expel, new column inserts). Update each window's layout
            # in-place so pos_in_scrolling_layout reflects current state.
            for change in event["WindowLayoutsChanged"].get("changes", []):
                # changes is a list of [window_id, layout] pairs
                if not isinstance(change, (list, tuple)) or len(change) != 2:
                    continue
                wid, layout = change
                if wid in self._windows:
                    self._windows[wid]["layout"] = layout
            self._full_rebuild()

    def _sync_focus_from_windows(self):
        self._focused_window_id = None
        self._focused_ws_id = None
        for w in self._windows.values():
            if w.get("is_focused"):
                self._focused_window_id = w["id"]
                self._focused_ws_id = w.get("workspace_id")
                break

    def _sync_ws_focus(self):
        for ws in self._workspaces.values():
            if ws.get("is_focused"):
                self._focused_ws_id = ws["id"]
                break


