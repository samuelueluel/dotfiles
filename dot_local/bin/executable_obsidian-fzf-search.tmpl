#!/usr/bin/env bash
OBSIDIAN_JSON="${HOME}/.var/app/md.obsidian.Obsidian/config/obsidian/obsidian.json"
VAULT_DIR=$(python3 -c "
import json, sys
data = json.load(open('${OBSIDIAN_JSON}'))
vaults = list(data.get('vaults', {}).values())
open_vault = next((v for v in vaults if v.get('open')), vaults[0])
print(open_vault['path'])
" 2>/dev/null)

if [ -z "$VAULT_DIR" ]; then
    echo "obsidian-fzf-search: could not determine vault path from ${OBSIDIAN_JSON}" >&2
    exit 1
fi

VAULT_NAME=$(basename "$VAULT_DIR")
echo -n "Search content: "
read -r query
[ -z "$query" ] && exit 0

selected=$(rg -l --glob "*.md" "$query" "$VAULT_DIR" |
    sed "s|$VAULT_DIR/||" |
    fzf --preview "rg --color=always -C2 '$query' \"$VAULT_DIR\"/{}" \
        --preview-window=right:60%:wrap)

if [ -n "$selected" ]; then
    if obsidian files total >/dev/null 2>&1; then
        obsidian open "path=$selected" newtab
    else
        encoded=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$selected")
        setsid xdg-open "obsidian://open?vault=${VAULT_NAME}&file=${encoded}" >/dev/null 2>&1 &
        disown
    fi
    ya emit-to "$YAZI_ID" quit 2>/dev/null
fi
