    "dockerfile": {
      "manifest": {
        "id": "dockerfile",
        "name": "Dockerfile",
        "version": "0.2.0",
        "schema_version": 1,
        "description": "Dockerfile support.",
        "repository": "https://github.com/zed-extensions/dockerfile",
        "authors": [
          "d1y <chenhonzho@gmail.com>",
          "joshmeads <github@joshmeads.com>"
        ],
        "lib": {
          "kind": "Rust",
          "version": "0.7.0"
        },
        "themes": [],
        "icon_themes": [],
        "languages": [
          "languages/dockerfile"
        ],
        "grammars": {
          "dockerfile": {
            "repository": "https://github.com/camdencheek/tree-sitter-dockerfile",
            "rev": "868e44ce378deb68aac902a9db68ff82d2299dd0",
            "path": null
          }
        },
        "language_servers": {
          "docker-language-server": {
            "language": "Dockerfile",
