          "dockerfile-language-server": {
            "language": "Dockerfile",
            "languages": [],
            "language_ids": {},
            "code_action_kinds": null
          }
        },
        "context_servers": {},
        "agent_servers": {},
        "slash_commands": {},
        "snippets": null,
        "capabilities": [],
        "debug_adapters": {
          "buildx-dockerfile": {
            "schema_path": "debug_adapter_schemas/buildx-dockerfile.json"
          }
        }
      },
      "dev": false
    }
  },
  "themes": {},
  "icon_themes": {},
  "languages": {
    "CSV": {
      "extension": "csv",
      "path": "languages/csv",
      "matcher": {
        "path_suffixes": [
          "csv"
        ],
        "first_line_pattern": null,
        "modeline_aliases": []
      },
      "hidden": false,
      "grammar": "csv"
    },
    "Dockerfile": {
      "extension": "dockerfile",
      "path": "languages/dockerfile",
      "matcher": {
        "path_suffixes": [
          "Dockerfile",
          "Containerfile",
          "dockerfile"
        ],
        "first_line_pattern": null,
        "modeline_aliases": []
      },
      "hidden": false,
      "grammar": "dockerfile"
    }
  }
