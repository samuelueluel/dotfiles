    "tokenColors": [
        { "scope": "comment",                                           "settings": { "foreground": "#D0A7AF", "fontStyle": "italic" } },
        { "scope": "string",                                            "settings": { "foreground": "#7DC4A0" } },
        { "scope": "constant.numeric",                                  "settings": { "foreground": "#FFA726" } },
        { "scope": "constant.language",                                 "settings": { "foreground": "#1AAAD4" } },
        { "scope": "keyword",                                           "settings": { "foreground": "#FFA726", "fontStyle": "bold" } },
        { "scope": ["keyword.operator", "keyword.other"],              "settings": { "foreground": "#1AAAD4", "fontStyle": "" } },
        { "scope": ["entity.name.function", "support.function"],       "settings": { "foreground": "#1AAAD4" } },
        { "scope": ["entity.name.type", "entity.name.class",
                     "support.type", "support.class"],                 "settings": { "foreground": "#FF6EB4" } },
        { "scope": "variable",                                          "settings": { "foreground": "#FFFFFF" } },
        { "scope": "variable.language",                                 "settings": { "foreground": "#FFA726" } },
        { "scope": "entity.name.tag",                                   "settings": { "foreground": "#FFFFFF" } },
        { "scope": "entity.other.attribute-name",                       "settings": { "foreground": "#1AAAD4" } },
        { "scope": "punctuation",                                       "settings": { "foreground": "#D0A7AF" } },
        { "scope": "storage.type",                                      "settings": { "foreground": "#FFA726", "fontStyle": "bold" } },
        { "scope": "storage.modifier",                                  "settings": { "foreground": "#FF6EB4" } },
        { "scope": "invalid",                                           "settings": { "foreground": "#FFFFFF", "background": "#FF6EB4" } }
    ]
}
