    "tokenColors": [
        { "scope": "comment",                                           "settings": { "foreground": "#c99e76", "fontStyle": "italic" } },
        { "scope": "string",                                            "settings": { "foreground": "#A1C4B4" } },
        { "scope": "constant.numeric",                                  "settings": { "foreground": "#D4B820" } },
        { "scope": "constant.language",                                 "settings": { "foreground": "#1AAAD4" } },
        { "scope": "keyword",                                           "settings": { "foreground": "#D4B820", "fontStyle": "bold" } },
        { "scope": ["keyword.operator", "keyword.other"],              "settings": { "foreground": "#1AAAD4", "fontStyle": "" } },
        { "scope": ["entity.name.function", "support.function"],       "settings": { "foreground": "#1AAAD4" } },
        { "scope": ["entity.name.type", "entity.name.class",
                     "support.type", "support.class"],                 "settings": { "foreground": "#ED6D42" } },
        { "scope": "variable",                                          "settings": { "foreground": "#F0B6B6" } },
        { "scope": "variable.language",                                 "settings": { "foreground": "#D4B820" } },
        { "scope": "entity.name.tag",                                   "settings": { "foreground": "#F0B6B6" } },
        { "scope": "entity.other.attribute-name",                       "settings": { "foreground": "#1AAAD4" } },
        { "scope": "punctuation",                                       "settings": { "foreground": "#c99e76" } },
        { "scope": "storage.type",                                      "settings": { "foreground": "#D4B820", "fontStyle": "bold" } },
        { "scope": "storage.modifier",                                  "settings": { "foreground": "#ED6D42" } },
        { "scope": "invalid",                                           "settings": { "foreground": "#F0B6B6", "background": "#ED6D42" } }
    ]
}
