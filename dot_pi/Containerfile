FROM docker.io/homebrew/ubuntu24.04:latest

# Copy your host's Brewfile
COPY dot_Brewfile-container /tmp/Brewfile

# Run your Brewfile
RUN brew bundle --file=/tmp/Brewfile

# Ensure pi and its extensions are available globally
RUN npm install -g pi-mcp-adapter pi-agent-extensions pi-web-access pi-markdown-preview

ENTRYPOINT ["pi"]
