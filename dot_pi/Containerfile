FROM docker.io/library/ubuntu:26.04

RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    file \
    git \
    procps \
    pulseaudio-utils \
    && rm -rf /var/lib/apt/lists/*

RUN NONINTERACTIVE=1 bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

ENV PATH="/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:$PATH"

COPY dot_Brewfile-container /tmp/Brewfile
RUN brew bundle --file=/tmp/Brewfile --jobs=1

RUN npm install -g pi-mcp-adapter pi-agent-extensions pi-web-access pi-markdown-preview

# tmux config loaded by the launch wrappers (podman run --entrypoint tmux ... -f /etc/pi-tmux.conf).
# tmux daemonizes its server, which double-forks and reparents to PID 1 (tini). Without this,
# closing the terminal kills only the tmux client; the detached server keeps tini alive, so the
# container never stops and `podman run` never returns — which freezes the whole single-instance
# Ghostty process. These two lines make the server die the instant the last client goes away,
# so the container tears down cleanly on terminal close.
RUN printf 'if-shell "test -f ~/.tmux.conf" "source-file ~/.tmux.conf"\nset -g destroy-unattached on\nset-hook -g client-detached "kill-server"\nset -g extended-keys on\nset -g extended-keys-format csi-u\n' > /etc/pi-tmux.conf

ENTRYPOINT ["pi"]
