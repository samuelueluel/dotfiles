# Show exactly which model file and settings are loaded on each port.
# Parses both the /v1/models API and the host process list for the exact .gguf name and MTP status.
model-check() {
  local p name id tag full_cmd exact_file mtp_status p_status
  for entry in "8080:main" "8081:autocomplete" "8082:embedder"; do
    p="${entry%%:*}"; name="${entry##*:}"
    
    # Get the base ID from the API to confirm it is actually responding
    id=$(curl -sf "http://localhost:$p/v1/models" 2>/dev/null \
           | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)
           
    if [[ -z "$id" ]]; then
      printf '  :%s  %-13s —\n' "$p" "$name"
      continue
    fi
    
    # Grab the running command to find the true filename and MTP status
    full_cmd=$(ps -eo args | grep "[l]lama-server" | grep -- "--port $p" | head -1)
    
    if [[ -n "$full_cmd" ]]; then
      exact_file=$(echo "$full_cmd" | grep -o -- '--model [^ ]*' | cut -d' ' -f2 | xargs basename 2>/dev/null)
      [[ -z "$exact_file" ]] && exact_file="$id"
      
      if echo "$full_cmd" | grep -q "draft-mtp"; then
        mtp_status=" [MTP: ON]"
      else
        [[ "$p" == 8080 ]] && mtp_status=" [MTP: OFF]" || mtp_status=""
      fi
      
      tag=""
      [[ "$p" == 8080 ]] && { [[ "$id" == *A[0-9]*B* ]] && tag=" (MoE)" || tag=" (dense)"; }
      
      p_status=""
      if [[ "$p" == 8080 ]]; then
        local parallel_slots="1"
        if echo "$full_cmd" | grep -q -- "--parallel"; then
          parallel_slots=$(echo "$full_cmd" | grep -o -- '--parallel [0-9]*' | cut -d' ' -f2)
        fi
        local actual_ctx=$(curl -sf "http://localhost:$p/props" 2>/dev/null | jq -r '.default_generation_settings.n_ctx' 2>/dev/null)
        if [[ -n "$actual_ctx" && "$actual_ctx" != "null" ]]; then
          p_status=" [p${parallel_slots} | $(( actual_ctx / 1000 ))k ctx]"
        else
          p_status=" [p${parallel_slots}]"
        fi
      fi
      
      printf '  :%s  %-13s %s%s%s%s\n' "$p" "$name" "$exact_file" "$tag" "$mtp_status" "$p_status"
    else
      # Fallback if parsing fails but API responded
      printf '  :%s  %-13s %s\n' "$p" "$name" "$id"
    fi
  done

  # Pi cloud agents — read state files written by pi-cloud / tau-cloud
  echo ""
  local _state_dir="$HOME/.pi/running"
  local _found_pi=0 _f _spid _type _m _t _short
  if [[ -d "$_state_dir" ]]; then
    for _f in "$_state_dir"/*.state(N); do
      _spid="${${_f:t}%.state}"
      # Skip stale files (shell that launched pi is gone)
      kill -0 "$_spid" 2>/dev/null || { rm -f "$_f"; continue; }
      _type=$(grep '^type=' "$_f" | cut -d= -f2)
      _m=$(grep    '^model=' "$_f" | cut -d= -f2)
      _t=$(grep    '^thinking=' "$_f" | cut -d= -f2)
      case "$_m" in
        *deepseek-v4-pro)   _short="dsv4pro" ;;
        *deepseek-v4-flash) _short="dsv4fl"  ;;
        *claude-opus-4*)    _short="opus"    ;;
        *glm-5.2*)          _short="glm52"   ;;
        *)                  _short="$_m"     ;;
      esac
      printf '  %-10s  %-8s  thinking: %s\n' "$_type" "$_short" "$_t"
      _found_pi=1
    done
  fi
  (( _found_pi )) || printf '  pi-cloud  —\n'
}


# Disable legacy Claude Code fallback (prevents reading CLAUDE.md)
export OPENCODE_DISABLE_CLAUDE_CODE=1

alias opencode-rebuild='podman build --no-cache -t localhost/opencode-safe:latest "$HOME/.config/opencode"'

_opencode_sync_context() {
  local server_ctx
  server_ctx=$(curl -sf "http://localhost:8080/props" 2>/dev/null | jq -r '.default_generation_settings.n_ctx' 2>/dev/null)
  local config_file="$HOME/.config/opencode/opencode.jsonc"
  if [[ -f "$config_file" ]]; then
    if [[ -n "$server_ctx" && "$server_ctx" =~ ^[0-9]+$ ]]; then
      sed -i -E "s/\"context\": [0-9]+/\"context\": $server_ctx/g" "$config_file"
    else
      sed -i -E "s/\"context\": [0-9]+/\"context\": 262144/g" "$config_file"
    fi
  fi
}

opencode() {
  _opencode_sync_context
  command opencode "$@"
}

opencode-safe-1() {
  _opencode_sync_context
  local target_dir="${1:-$PWD}"
  local abs_dir="$(realpath "$target_dir")"

  if [[ "$abs_dir" == "$HOME" ]]; then
    echo "Error: Cannot run opencode-safe-1 with write access to your entire home directory."
    return 1
  fi

  echo -e "\033[33mWARNING: You are giving OpenCode WRITE access to directory: $abs_dir (including subdirectories)\033[0m"
  echo -e "\033[33mAnd READ access to everywhere else in: $HOME\033[0m"
  if read -q "choice?Do you want to proceed? [y/N] "; then
    echo
  else
    echo -e "\nAborted."
    return 1
  fi

  setopt localtraps
  local container_name="opencode-safe-1-$$"
  trap 'podman kill "$container_name" 2>/dev/null' EXIT INT TERM

  podman run --init -it --rm \
    --name "$container_name" \
    --network=host \
    --userns=keep-id \
    --security-opt label=disable \
    -e HOME="$HOME" \
    -e TERM=xterm-256color \
    -e COLORTERM \
    -e LANG \
    -v "$HOME":"$HOME":ro \
