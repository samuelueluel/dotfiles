# Local LLM (Ramalama / Goose / Aider) — §2.B, §2.D, §2.F
export OPENAI_API_KEY=sk-6869f13e80764e0ab07cb09a9ef5ea98
RAMA_IMG=docker.io/kyuz0/amd-strix-halo-toolboxes:vulkan-radv
MTP_OPTS="--spec-type draft-mtp --spec-draft-n-max 2 --spec-draft-p-min 0.75"
CTX=131072  # context window for the server (applies to ALL clients: WebUI, Goose, etc.)

# Stop the MAIN-model container (only) AND wait for :8080 to release before re-serving.
# Stops just 'llm' (not --all) so the :8081 autocomplete model survives a main-model swap.
# Without the wait, ramalama serve races the old socket, finds 8080 "busy", and
# silently auto-assigns a random port — breaking every client (WebUI/Goose/aider).
_llm_reset() {
  ramalama stop llm 2>/dev/null
  local i=0
  while ss -tln 2>/dev/null | grep -q ':8080 ' && (( i < 30 )); do sleep 0.5; (( i++ )); done
}

serve-llm() {
  _llm_reset
  ramalama serve -d -n llm -p 8080 --image "$RAMA_IMG" --ctx-size "$CTX" --runtime-args "$MTP_OPTS" "$1" \
    && echo "▶ serving $1 (MTP, ctx $CTX) at http://localhost:8080/v1"
}
serve-llm-nospec() {  # same model, MTP off — for quality A/B vs the MTP-on alias
  _llm_reset
  ramalama serve -d -n llm -p 8080 --image "$RAMA_IMG" --ctx-size "$CTX" "$1" \
    && echo "▶ serving $1 (no MTP, ctx $CTX) at http://localhost:8080/v1"
}
# Three "main models" — they swap through the one :8080 slot (container 'llm'), one at a time:
#   serve-code  → fast MoE, everyday agentic driver (Goose/Aider/terminal)
#   serve-think → dense reasoning, high-stakes paper critique/synthesis
#   serve-edit  → Gemma 4 31B, copyediting + hard statistical/math coding (NOT agentic loops)
alias serve-code='serve-llm hf://unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q8_K_XL'
alias serve-code-nospec='serve-llm-nospec hf://unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q8_K_XL'
alias serve-think='serve-llm hf://unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q8_K_XL'
alias serve-edit='serve-llm-nospec hf://unsloth/gemma-4-31b-it-GGUF:Q8_0'
alias stop-main='ramalama stop llm'  # stops whichever main model (:8080) is loaded

# Small FIM autocomplete model for VS Code (Continue → :8081). Runs on the iGPU ALONGSIDE
# the main model, on its own name/port so a main-model swap doesn't evict it. No MTP (not an
# MTP build); small ctx since autocomplete prompts are short. The NPU has no coder model, so
# real code completion has to live on the iGPU — §2.J / §8.E.2. Served id: Qwen/Qwen2.5-Coder-1.5B-Instruct-GGUF
AUTOCOMPLETE_MODEL=hf://Qwen/Qwen2.5-Coder-1.5B-Instruct-GGUF:Q4_K_M
serve-autocomplete() {
  ramalama stop coder 2>/dev/null
  local i=0
  while ss -tln 2>/dev/null | grep -q ':8081 ' && (( i < 30 )); do sleep 0.5; (( i++ )); done
  ramalama serve -d -n coder -p 8081 --image "$RAMA_IMG" --ctx-size 8192 "$AUTOCOMPLETE_MODEL" \
    && echo "▶ serving autocomplete (FIM) at http://localhost:8081/v1"
}
alias stop-autocomplete='ramalama stop coder'

# Serve an embedder model on the iGPU alongside the main model and autocomplete
EMBED_MODEL="hf://Qwen/Qwen3-Embedding-8B-GGUF:Q4_K_M"
serve-embedder() {
  ramalama stop embedder 2>/dev/null
  local i=0
  while ss -tln 2>/dev/null | grep -q ':8082 ' && (( i < 30 )); do sleep 0.5; (( i++ )); done
  ramalama serve -d -n embedder -p 8082 --image "$RAMA_IMG" --ctx-size 8192 --runtime-args="--embedding" "$EMBED_MODEL" \
