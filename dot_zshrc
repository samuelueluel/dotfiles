# Better globbing tools (assuming you enabled extendedglob earlier)
setopt EXTENDED_GLOB

# Quality-of-life: no terminal bell (assuming you disabled beep earlier)
unsetopt BEEP

# Safer glob behavior (keep nomatch on; optional nullglob behavior via (N) when needed)
