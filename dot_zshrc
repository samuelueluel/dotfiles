goose-safe-3() {
  local target_file="${1}"
  local model_name="${2}"

  if [[ -z "$target_file" || ! -f "$target_file" ]]; then
    echo "Error: goose-safe-3 requires a specific existing FILE as an argument."
    echo "Usage: goose-safe-3 /path/to/file.ext [model_name]"
    return 1
  fi

  if [[ -z "$model_name" ]]; then
    model_name=$(curl -sf http://localhost:8080/v1/models | python3 -c "import sys, json; print(json.load(sys.stdin)['data'][0]['id'])" 2>/dev/null)
    if [[ -z "$model_name" ]]; then
      echo -e "\033[31mError: Could not detect a model on localhost:8080. Are you sure the engine is running?\033[0m"
      return 1
    fi
  fi

  local abs_file="$(realpath "$target_file")"
  local abs_dir="$(dirname "$abs_file")"

  echo -e "\033[33mWARNING: You are giving Goose WRITE access to exactly ONE FILE: $abs_file\033[0m"
  echo -e "\033[33mAnd READ access to everywhere else in: $HOME\033[0m"
  echo -e "\033[33m(A writable, temporary in-memory /tmp is also provided)\033[0m"
  echo -e "\033[36mModel auto-detected: $model_name\033[0m"
  if read -q "choice?Do you want to proceed? [y/N] "; then
    echo
  else
    echo -e "\nAborted."
    return 1
  fi

  local cfg; cfg=$(_goose_tmp_config "$model_name")
  # --tmpfs /tmp creates a writable, temporary in-memory scratchpad.
  # -v "$abs_file":"$abs_file" mounts just the specific file as writable over the RO home mount.
  podman run -it --rm \
    --network=host \
    --userns=keep-id \
    --security-opt label=disable \
    -v "$HOME":"$HOME":ro \
    -v "$abs_file":"$abs_file" \
    -v "$cfg":/home/goose/.config/goose:z \
    --tmpfs /tmp \
    -w "$abs_dir" \
    ghcr.io/block/goose:latest \
    session "${@:3}"
  rm -rf "$cfg"
}
