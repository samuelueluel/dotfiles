# Modern CLI defaults if installed
command -v eza >/dev/null && alias ls='eza --group-directories-first --icons'
command -v eza >/dev/null && alias ll='eza -lah --group-directories-first --icons'
command -v bat >/dev/null && alias cat='bat'
#command -v rg  >/dev/null && alias grep='rg'

# zoxide: smart cd
if command -v zoxide >/dev/null; then
  eval "$(zoxide init zsh)"
fi

# fzf keybindings/completion (path varies by distro)
for f in /usr/share/fzf/shell/key-bindings.zsh /usr/share/fzf/shell/completion.zsh; do
  [ -f "$f" ] && source "$f"
done

# SSH agent: start if not running, add key if not loaded
# (must be before p10k instant prompt to avoid console output warnings)
if ! pgrep -u "$USER" ssh-agent > /dev/null; then
  eval "$(ssh-agent -s)" > /dev/null
fi
if ! ssh-add -l > /dev/null 2>&1; then
  ssh-add ~/.ssh/id_ed25519 > /dev/null 2>&1
fi

