# Creates a temp dir with goose config for the containerised binary (v1.30.x).
# Returns the dir path; caller mounts it at /home/goose/.config/goose (writable, not :ro).
# v1.30.x uses flat GOOSE_PROVIDER/GOOSE_MODEL keys, not the providers: nesting of v1.36.x.
_goose_tmp_config() {
  local model_name="$1"
  local cfgdir
  cfgdir=$(mktemp -d)
  cat > "$cfgdir/config.yaml" <<YAML
GOOSE_TELEMETRY_ENABLED: true
GOOSE_PROVIDER: openai
GOOSE_MODEL: $model_name
OPENAI_BASE_URL: http://localhost:8080/v1
OPENAI_HOST: http://localhost:8080
OPENAI_BASE_PATH: v1/chat/completions
OPENAI_API_KEY: dummy
GOOSE_CLI_THEME: dark
GOOSE_CLI_DARK_THEME: gruvbox-dark
YAML
  echo "$cfgdir"
}

goose-safe-1() {
  local target_dir="${1:-$PWD}"
  local model_name="${2}"
  local abs_dir="$(realpath "$target_dir")"

  if [[ "$abs_dir" == "$HOME" ]]; then
    echo "Error: Cannot run goose-safe-1 with write access to your entire home directory."
    return 1
  fi

  if [[ -z "$model_name" ]]; then
    model_name=$(curl -sf http://localhost:8080/v1/models | python3 -c "import sys, json; print(json.load(sys.stdin)['data'][0]['id'])" 2>/dev/null)
    if [[ -z "$model_name" ]]; then
      echo -e "\033[31mError: Could not detect a model on localhost:8080. Are you sure the engine is running?\033[0m"
      return 1
    fi
  fi

  echo -e "\033[33mWARNING: You are giving Goose WRITE access to directory: $abs_dir (including subdirectories)\033[0m"
  echo -e "\033[33mAnd READ access to everywhere else in: $HOME\033[0m"
  echo -e "\033[36mModel auto-detected: $model_name\033[0m"
  if read -q "choice?Do you want to proceed? [y/N] "; then
    echo
  else
    echo -e "\nAborted."
    return 1
  fi

  local cfg; cfg=$(_goose_tmp_config "$model_name")
  # --security-opt label=disable prevents SELinux from recursively relabeling the entire $HOME.
  # The more specific mount (-v $abs_dir) overrides the read-only $HOME mount.
  # --network=host gives it full internet access to search online generally.
  podman run -it --rm \
    --network=host \
    --userns=keep-id \
    --security-opt label=disable \
    -v "$HOME":"$HOME":ro \
    -v "$abs_dir":"$abs_dir" \
    -v "$cfg":/home/goose/.config/goose:z \
    -w "$abs_dir" \
    ghcr.io/block/goose:latest \
    session "${@:3}"
  rm -rf "$cfg"
}

