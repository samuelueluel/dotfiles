alias goose-rebuild='podman build --no-cache -t localhost/goose-safe:latest "$HOME/.config/goose"'

_goose_resolve_params() {
  # 1. Query active model from local Ramalama instance
  local model_id
  model_id=$(curl -sf "http://localhost:8080/v1/models" 2>/dev/null \
         | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)

  # Dynamically fetch actual context slot size (n_ctx) from llama-server
  local server_ctx
  server_ctx=$(curl -sf "http://localhost:8080/props" 2>/dev/null \
         | jq -r '.default_generation_settings.n_ctx' 2>/dev/null)

  # 2. Defaults (aligned with opencode.jsonc)
  local ctx_limit=262144
  local max_tokens=16384
  local temp=0.6

  if [[ "$model_id" == *Qwen3.6-35B-A3B* ]]; then
    ctx_limit=262144
    max_tokens=16384
  elif [[ "$model_id" == *Qwen3.6-27B* ]]; then
    ctx_limit=262144
    max_tokens=16384
  fi

  # 3. Dynamic context override (safe clamp)
  # If the server reports a smaller slot size (e.g. 131072 from -p2), trust the server
  if [[ -n "$server_ctx" && "$server_ctx" =~ ^[0-9]+$ ]]; then
    if (( server_ctx < ctx_limit )); then
      ctx_limit="$server_ctx"
    fi
  fi

  export GOOSE_CONTEXT_LIMIT="$ctx_limit"
  export GOOSE_MAX_TOKENS="$max_tokens"
  export GOOSE_TEMPERATURE="$temp"
  export GOOSE_MODE="smart_approve"
}

goose() {
  local clean_args=()
  local skills=()
  
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skill)
        skills+=("$2")
        shift 2
        ;;
      *)
        clean_args+=("$1")
        shift
        ;;
    esac
  done

  _goose_resolve_params

  local tmpfile=""
  if [[ ${#skills[@]} -gt 0 ]]; then
    tmpfile="/tmp/goose_skills_$$"
    cat "${skills[@]}" > "$tmpfile"
    
    GOOSE_MOIM_MESSAGE_FILE="$tmpfile" command goose "${clean_args[@]}"
    local ret=$?
    rm -f "$tmpfile"
    return $ret
  else
    command goose "${clean_args[@]}"
  fi
}

goose-safe-1() {
  local target_dir="${1:-$PWD}"
  local abs_dir="$(realpath "$target_dir")"

  if [[ "$abs_dir" == "$HOME" ]]; then
    echo "Error: Cannot run goose-safe-1 with write access to your entire home directory."
    return 1
  fi

  local clean_args=()
  local skills=()
  
  [[ $# -gt 0 ]] && shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skill)
        skills+=("$2")
        shift 2
        ;;
      *)
        clean_args+=("$1")
        shift
        ;;
    esac
  done

  _goose_resolve_params

  echo -e "[33mWARNING: You are giving Goose WRITE access to directory: $abs_dir (including subdirectories)[0m"
  echo -e "[33mAnd READ access to everywhere else in: $HOME[0m"
  if ! read -q "choice?Do you want to proceed? [y/N] "; then
    echo -e "
Aborted."
