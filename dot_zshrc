    cat "${skills[@]}" > "$tmpfile"
    moim_arg="-e GOOSE_MOIM_MESSAGE_FILE=$tmpfile -v $tmpfile:$tmpfile"
  fi

  podman run --init -it --rm \
    --name "$container_name" \
    --network=host \
    --userns=keep-id \
    --security-opt label=disable \
    -e HOME="$HOME" \
    -e TERM \
    -e COLORTERM \
    -e LANG \
    -e GOOSE_CONTEXT_LIMIT \
    -e GOOSE_MAX_TOKENS \
    -e GOOSE_TEMPERATURE \
    -e GOOSE_MODE \
    $moim_arg \
    -v "$HOME":"$HOME":ro \
    -v "$abs_dir":"$abs_dir" \
    -v "$HOME/.config/goose":"$HOME/.config/goose" \
    -v "$HOME/.local/state/goose":"$HOME/.local/state/goose" \
    -v "$HOME/.local/share/goose":"$HOME/.local/share/goose" \
    -v "/home/linuxbrew/.linuxbrew":"/home/linuxbrew/.linuxbrew":ro \
    -v "$HOME/.agents":"$HOME/.agents":ro \
    -w "$abs_dir" \
    localhost/goose-safe:latest session "${clean_args[@]}"
    
  if [[ -n "$tmpfile" ]]; then rm -f "$tmpfile"; fi
}

