umask 002
export EDITOR="zed --wait"
export SUDO_EDITOR="zed --wait"

# Lines configured by zsh-newuser-install
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt extendedglob
unsetopt beep

# Vi mode
bindkey -v
KEYTIMEOUT=1

# Cursor: beam in insert, block in normal
function zle-keymap-select {
  if [[ ${KEYMAP} == vicmd ]]; then
    echo -ne '\e[2 q\e]12;#ED6D42\a'  # block + gold (normal/nav)
  else
    echo -ne '\e[2 q\e]12;#1AAAD4\a'  # block + teal (insert/type)
  fi
}
zle -N zle-keymap-select
function zle-line-init { echo -ne '\e[2 q\e]12;#1AAAD4\a' }
zle -N zle-line-init

# History (large, shared across sessions, deduped)
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt INC_APPEND_HISTORY

# Better globbing tools
setopt EXTENDED_GLOB

# Quality-of-life: no terminal bell
unsetopt BEEP

# Safer glob behavior
setopt NOMATCH

# Modern CLI defaults if installed
command -v eza >/dev/null && alias ls='eza --group-directories-first --icons'
command -v eza >/dev/null && alias ll='eza -lah --group-directories-first --icons'
command -v bat >/dev/null && alias cat='bat'

# Cache dir for init scripts
ZSH_CACHE="$HOME/.cache/zsh"
[[ -d "$ZSH_CACHE" ]] || mkdir -p "$ZSH_CACHE"

# fzf global options (colors, keybinds, UI)
export FZF_DEFAULT_OPTS="--bind 'alt-w:up,alt-s:down,alt-a:backward-char,alt-d:forward-char,alt-space:accept' --gutter=' ' --scrollbar='█' --color='bg:-1,gutter:-1,border:#6E3840,separator:#B06F75,preview-border:#B06F75,hl:#ED6D42,hl+:#ED6D42,pointer:#ED6D42,marker:#ED6D42,bg+:#000000,prompt:#ED6D42,info:#B06F75,header:#B06F75,scrollbar:#ED6D42'"

