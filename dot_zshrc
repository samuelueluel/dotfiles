# Show exactly which model file and settings are loaded on each port.
# Parses both the /v1/models API and the host process list for the exact .gguf name and MTP status.
model-check() {
  local p name id tag full_cmd exact_file mtp_status
  for entry in "8080:main" "8081:autocomplete" "8082:embedder"; do
    p="${entry%%:*}"; name="${entry##*:}"
    
    # Get the base ID from the API to confirm it is actually responding
    id=$(curl -sf "http://localhost:$p/v1/models" 2>/dev/null \
           | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)
           
    if [[ -z "$id" ]]; then
      printf '  :%s  %-13s —\n' "$p" "$name"
      continue
    fi
    
    # Grab the running command to find the true filename and MTP status
    full_cmd=$(ps -eo args | grep "[l]lama-server" | grep -- "--port $p" | head -1)
    
    if [[ -n "$full_cmd" ]]; then
      exact_file=$(echo "$full_cmd" | grep -o -- '--model [^ ]*' | cut -d' ' -f2 | xargs basename 2>/dev/null)
      [[ -z "$exact_file" ]] && exact_file="$id"
      
      if echo "$full_cmd" | grep -q "draft-mtp"; then
        mtp_status=" [MTP: ON]"
      else
        [[ "$p" == 8080 ]] && mtp_status=" [MTP: OFF]" || mtp_status=""
      fi
      
      tag=""
      [[ "$p" == 8080 ]] && { [[ "$id" == *A[0-9]*B* ]] && tag=" (MoE)" || tag=" (dense)"; }
      
      printf '  :%s  %-13s %s%s%s\n' "$p" "$name" "$exact_file" "$tag" "$mtp_status"
    else
      # Fallback if parsing fails but API responded
      printf '  :%s  %-13s %s\n' "$p" "$name" "$id"
    fi
  done
}


alias opencode-rebuild='podman build --no-cache -t localhost/opencode-safe:latest "$HOME/.config/opencode"'

opencode-safe-1() {
  local target_dir="${1:-$PWD}"
  local abs_dir="$(realpath "$target_dir")"

  if [[ "$abs_dir" == "$HOME" ]]; then
    echo "Error: Cannot run opencode-safe-1 with write access to your entire home directory."
    return 1
  fi

  echo -e "\033[33mWARNING: You are giving OpenCode WRITE access to directory: $abs_dir (including subdirectories)\033[0m"
  echo -e "\033[33mAnd READ access to everywhere else in: $HOME\033[0m"
  if read -q "choice?Do you want to proceed? [y/N] "; then
    echo
  else
    echo -e "\nAborted."
    return 1
  fi

  setopt localtraps
  local container_name="opencode-safe-1-$$"
  trap 'podman kill "$container_name" 2>/dev/null' EXIT HUP INT TERM

  podman run -it --rm \
    --name "$container_name" \
    --network=host \
    --userns=keep-id \
    --security-opt label=disable \
    -e HOME="$HOME" \
    -v "$HOME":"$HOME":ro \
    -v "$abs_dir":"$abs_dir" \
    -v "$HOME/.config/opencode":"$HOME/.config/opencode":ro \
    -v "$HOME/.local/share/opencode":"$HOME/.local/share/opencode" \
    -v "$HOME/.local/state/opencode":"$HOME/.local/state/opencode" \
    -v "$HOME/.cache/opencode":"$HOME/.cache/opencode" \
    -w "$abs_dir" \
    localhost/opencode-safe:latest "${@:2}"
}

