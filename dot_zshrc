# Update function
function update-all() {
    print -P "\n%F{blue}=== Checking Arch News (Informant) ===%f"
    print -P "%F{cyan}  \$ informant check%f  # check for unread Arch Linux news before updating"
    informant check || { print -P "%F{red}  Read the news above before continuing. Aborting.%f"; return 1; }

    print -P "\n%F{blue}=== Empty Trash? ===%f"
    read -q "REPLY?  Empty trash now? (y/n) " && trash-empty -f
    print ""

    print -P "\n%F{blue}=== System Health Check ===%f"
    print -P "%F{cyan}  \$ systemctl --failed%f  # show any failed services"
    systemctl --failed
    print -P "%F{cyan}  \$ journalctl -p 3 -b%f  # errors/criticals this boot (excluding core dumps)"
    journalctl -p 3 -b | grep -Pv "(systemd-coredump|^\s{10,}|org\.freedesktop\.FileManager1)"

    print -P "\n%F{blue}=== Updating Pacman + AUR Packages ===%f"
    print -P "%F{cyan}  \$ yay -Syu%f"
    yay -Syu

    print -P "\n%F{blue}=== Checking for Packages Needing Rebuild ===%f"
    print -P "%F{cyan}  \$ checkrebuild%f  # find AUR packages linked against updated libraries"
    # Packages known to false-positive (bundle their own libs or are pre-built binaries)
    local rebuild_exclude=(librewolf-bin qt5-webengine)
    local rebuild_pkgs
    rebuild_pkgs=$(checkrebuild 2>/dev/null | awk '{print $2}' | grep -Fxv "$(printf '%s\n' "${rebuild_exclude[@]}")")
    if [[ -n "$rebuild_pkgs" ]]; then
        print -P "%F{yellow}  Packages needing rebuild:%f"
        echo "$rebuild_pkgs"
        read -q "REPLY?  Rebuild these packages now with yay? (y/n) " && yay -S ${(f)rebuild_pkgs}
        print ""
    else
        print -P "%F{green}  No packages need rebuilding.%f"
    fi

    print -P "\n%F{blue}=== Backing Up Package Lists ===%f"
    print -P "%F{cyan}  saving explicit and AUR package lists to system_config_git/pkglists/%f"
    pacman -Qqen > ~/system_config_git/pkglists/pkglist_explicit.txt
    pacman -Qqem > ~/system_config_git/pkglists/pkglist_aur.txt
    print -P "%F{cyan}  \$ paccache -r%f  # keep last 3 versions of installed packages"
    paccache -r
    print -P "%F{cyan}  \$ paccache -ruk0%f  # remove all cached versions of uninstalled packages"
    paccache -ruk0

    print -P "\n%F{blue}=== Removing Orphaned Packages ===%f"
    print -P "%F{cyan}  \$ yay -Yc%f  # remove packages no longer needed as dependencies"
    yay -Yc

    print -P "\n%F{blue}=== Updating Flatpaks ===%f"
    print -P "%F{cyan}  \$ flatpak update -y --noninteractive%f"
    flatpak update -y --noninteractive

    print -P "\n%F{blue}=== Cleaning up unused Flatpak runtimes ===%f"
    sleep 2 # Sometimes this is buggy right after flatpak update
    print -P "%F{cyan}  \$ flatpak uninstall --unused -y --noninteractive%f  # system runtimes no app needs"
    flatpak uninstall --unused -y --noninteractive

    print -P "\n%F{blue}=== Updating Rust Toolchain + Cargo packages ===%f"
    print -P "%F{cyan}  \$ rustup update%f  # update Rust compiler and std lib for all installed toolchains"
    rustup update
    # Rebuild cargo-install-update if it's broken due to a library update (e.g. libgit2 ABI bump)
    if ! rustup run stable cargo install-update --version &>/dev/null; then
        print -P "%F{yellow}  cargo-install-update broken (library mismatch), rebuilding...%f"
        print -P "%F{cyan}  \$ cargo install cargo-update --force%f"
        rustup run stable cargo install cargo-update --force
    fi
    print -P "%F{cyan}  \$ cargo install-update -a%f  # update all binaries installed via 'cargo install'"
    rustup run stable cargo install-update -a

    print -P "\n%F{blue}=== Updating npm global packages ===%f"
    print -P "%F{cyan}  \$ npm update -g%f  # update all globally installed npm packages"
    npm update -g

    print -P "\n%F{blue}=== Checking ThinkPad Firmware/BIOS Updates ===%f"
    print -P "%F{cyan}  \$ fwupdmgr refresh%f  # fetch latest firmware metadata from LVFS"
    fwupdmgr refresh
    print -P "%F{cyan}  \$ fwupdmgr get-updates%f  # list available firmware updates"
    fwupdmgr get-updates
    print -P "%F{cyan}  \$ fwupdmgr update%f  # apply firmware updates"
    fwupdmgr update
    print -P "%F{cyan}  \$ sudo systemctl stop fwupd%f  # stop fwupd daemon until next update"
    sudo systemctl stop fwupd

    print -P "\n%F{blue}=== Checking for .pacnew Config Files ===%f"
    print -P "%F{cyan}  \$ eos-pacdiff%f  # show config files that need merging after package updates"
    eos-pacdiff

    print -P "%F{green}Update sequence complete! (If Niri or your kernel updated, you should reboot soon).%f\n"
}

