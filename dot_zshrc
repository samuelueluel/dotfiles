# Local LLM (Ramalama / OpenCode / Aider) — §2.B, §2.D, §2.F
# OPENAI_API_KEY is set in ~/.zshenv.local (placeholder for local llama.cpp compat)
RAMA_IMG=docker.io/kyuz0/amd-strix-halo-toolboxes:vulkan-radv
MTP_OPTS="-ngl 999 --no-mmap --direct-io --kv-unified -fa 1 -ub 2048 -b 8192 --spec-type draft-mtp --spec-draft-n-max 3 --spec-draft-p-min 0.75 -t 16 --slot-prompt-similarity 0.8 --cache-reuse 512 --ctx-checkpoints 8 --checkpoint-min-step 2048 --context-shift --cache-ram 61440"
# Cap thinking tokens to prevent infinite reasoning loops (post-Apr-10 llama.cpp bug: default budget = -1/unrestricted).
# 50000 is a loop-breaker, not a target: clears even very long legitimate reasoning, still well below a true (unbounded) runaway.
REASONING_OPTS="--reasoning on --reasoning-budget 50000"
# Injected verbatim BEFORE the </think> tag when the budget is hit — the model reads it as its own thought, then answers.
# So it must be natural first-person prose (the "Wait," cue redirects thinking models well), NOT a bracketed token.
# Passed via --env, not --runtime-args, so it can keep its spaces: ramalama word-splits --runtime-args. (llama.cpp: LLAMA_ARG_THINK_BUDGET_MESSAGE)
THINK_BUDGET_MSG="Wait, I've used my full reasoning budget and I'm starting to loop. I already have enough to answer well, so I'll stop thinking now and write my final response."
# Qwen3.6 reasoning-model sampling (coding-tuned). Set SERVER-SIDE because these are llama.cpp DEFAULTS that
# only apply when a client omits the field — so GUI clients (Open WebUI etc.) that send their own values still win,
# and this effectively only reaches clients that send nothing (e.g. Pi, which has no sampling config — feature req #1837).
# Values per Qwen thinking-mode guidance; presence-penalty kept mild (0.5) so it curbs loops without penalising the
# repeated brackets/indent/keywords that legitimately recur in code. Do NOT lower temp toward 0 — greedy decoding makes
# Qwen reasoning models loop. Applied to Qwen3.6 only (guarded by model id in the serve fns).
QWEN_SAMPLING="--temp 0.6 --top-p 0.95 --top-k 20 --min-p 0 --presence-penalty 0.5"
MTP_OPTS="$MTP_OPTS $REASONING_OPTS"
CTX=262144  # context window for the server (applies to ALL clients: WebUI, OpenCode, etc.)

# Stop the MAIN-model container (only) AND wait for :8080 to release before re-serving.
# Stops just 'llm' (not --all) so the :8081 autocomplete model survives a main-model swap.
# Without the wait, ramalama serve races the old socket, finds 8080 "busy", and
# silently auto-assigns a random port — breaking every client (WebUI/OpenCode/aider).
_llm_reset() {
  echo "Pulling latest $RAMA_IMG …"
  podman pull "$RAMA_IMG"
  ramalama stop llm 2>/dev/null
  local i=0
  while ss -tln 2>/dev/null | grep -q ':8080 ' && (( i < 30 )); do sleep 0.5; (( i++ )); done
}

# NOTE: The Qwen3.6 chat-template fix (froggeric) is applied by overwriting the
# chat_template_extracted blob in ramalama's store, NOT here. ramalama already mounts
# that blob into the container and auto-passes --chat-template-file, so a custom flag
# pointing at a host path would fail (host path isn't mounted in the container).
# Re-apply after a model re-pull: see ~/.local/share/ramalama/README-qwen-template.md
serve-llm() {
  _llm_reset
  local samp=""; [[ "$1" == *Qwen3.6* ]] && samp=" $QWEN_SAMPLING"  # Qwen3.6 only (MoE + Dense, MTP path)
  ramalama serve -d -n llm -p 8080 --image "$RAMA_IMG" --ctx-size "$CTX" --env "LLAMA_ARG_THINK_BUDGET_MESSAGE=$THINK_BUDGET_MSG" --runtime-args="$MTP_OPTS$samp" "$1" \
    && echo "▶ serving $1 (MTP, ctx $CTX) at http://localhost:8080/v1"
}
serve-llm-nospec() {  # same model, MTP off — for quality A/B vs the MTP-on alias
  _llm_reset
  local p_opts="${PARALLEL_OPTS:---parallel 1}"
  local samp=""; [[ "$1" == *Qwen3.6* ]] && samp=" $QWEN_SAMPLING"  # Qwen3.6 only (MoE + Dense, no-MTP path)
  ramalama serve -d -n llm -p 8080 --image "$RAMA_IMG" --ctx-size "$CTX" --env "LLAMA_ARG_THINK_BUDGET_MESSAGE=$THINK_BUDGET_MSG" --runtime-args="$p_opts $REASONING_OPTS$samp" "$1" \
    && echo "▶ serving $1 (no MTP, ctx $CTX, $p_opts) at http://localhost:8080/v1"
}
serve-llm-draft() {  # speculative decoding with a separate draft model
  echo "Ensuring draft model $2 is pulled..."
  ramalama pull "$2"
  _llm_reset
  local samp=""; [[ "$1" == *Qwen3.6* ]] && samp=" $QWEN_SAMPLING"  # Qwen3.6 guard
  ramalama serve -d -n llm -p 8080 --image "$RAMA_IMG" --ctx-size "$CTX" --env "LLAMA_ARG_THINK_BUDGET_MESSAGE=$THINK_BUDGET_MSG" --runtime-args="$MTP_OPTS $3$samp" --model-draft "$2" "$1" \
    && echo "▶ serving $1 with draft $2 (MTP, ctx $CTX) at http://localhost:8080/v1"
}
# Interactive main-model picker — gum menus for model / quant / MTP / parallel slots.
# Replaces the 20 individual serve-* aliases. Usage: serve-local
serve-local() {
  local model_key quant mtp parallel uri draft_uri mtp_opts_local
  local -a quant_opts

  model_key=$(gum choose \
    --header "serve · model" \
    "qwen-moe    Qwen3.6 MoE 35B-A3B" \
    "qwen-dense  Qwen3.6 Dense 27B") || return 1
  model_key="${model_key%%[ ]*}"

  case "$model_key" in
    qwen-moe)   quant_opts=("Q4" "Q8") ;;
    qwen-dense) quant_opts=("Q4" "Q8") ;;
  esac

  if [[ ${#quant_opts[@]} -gt 1 ]]; then
    quant=$(gum choose --header "serve · quantization" "${quant_opts[@]}") || return 1
  else
    quant="${quant_opts[1]}"
  fi

  mtp=$(gum choose --header "serve · MTP (multi-token prediction)" "on" "off") || return 1
  parallel=$(gum choose --header "serve · parallel slots" "1" "2") || return 1

  # Resolve URIs
  case "$model_key-$quant" in
    qwen-moe-Q4)    uri="hf://unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q4_K_XL" ;;
    qwen-moe-Q8)    uri="hf://unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q8_K_XL" ;;
    qwen-dense-Q4)  uri="hf://unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q4_K_XL"     ;;
    qwen-dense-Q8)  uri="hf://unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q8_K_XL"     ;;
  esac

  if [[ "$mtp" == "on" ]]; then
    # Qwen MoE Q8: cap spec-draft-n-max at 2 — n=3 benchmarked slower on Vulkan
    # (extra draft token compute overhead outweighs acceptance gain vs ROCm)
    if [[ "$model_key-$quant" == "qwen-moe-Q8" ]]; then
      mtp_opts_local="${MTP_OPTS/--spec-draft-n-max 3/--spec-draft-n-max 2} --parallel $parallel"
    else
      mtp_opts_local="$MTP_OPTS --parallel $parallel"
    fi
    MTP_OPTS="$mtp_opts_local" serve-llm "$uri"
  else
    PARALLEL_OPTS="--parallel $parallel" serve-llm-nospec "$uri"
  fi
}

