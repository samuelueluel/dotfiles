# Night light toggles
alias night-on="pkill wlsunset; nohup wlsunset -l 35.7 -L -105.9 >/dev/null 2>&1 &"
alias night-off="pkill wlsunset"

# fzf-tab: use the global fzf options
zstyle ':fzf-tab:*' use-fzf-default-opts yes

# Television: smart shell autocomplete (^T)
if command -v tv >/dev/null; then
  if [[ ! -f "$ZSH_CACHE/television.zsh" ]]; then
    tv init zsh > "$ZSH_CACHE/television.zsh"
    # Fix: Ensure enter key always confirms (pastes) during shell autocomplete
    # instead of triggering the channel's default action (like opening a file).
    sed -i 's/tv "$dir"/tv "$dir" --keybindings='\''enter="confirm_selection"'\''/' "$ZSH_CACHE/television.zsh"
    sed -i 's/| tv /| tv --keybindings='\''enter="confirm_selection"'\'' /' "$ZSH_CACHE/television.zsh"
  fi
  source "$ZSH_CACHE/television.zsh"
  # Restore Atuin history if it was overwritten
  if (( $+functions[atuin-search] )); then
    bindkey '^R' atuin-search
  fi
fi

# Snippets (via Television)
if command -v tv >/dev/null; then
  # pets: search and execute a snippet via television
  function pets() {
    tv "Snippets"
  }

  # prev: save the last executed command as a snippet
  function prev() {
    local last=$(fc -lrn | head -1 | xargs)
    echo -n "Description for '$last': "
    read desc
    if [[ -n "$desc" ]]; then
      echo "- $desc | $last" >> "$HOME/.config/television/snippets.md"
      echo "Saved to Snippets. (Run 'chezmoi add ~/.config/television/snippets.md' to persist to dotfiles)"
    fi
  }
fi

# Auto-load SSH key on first terminal (added by sjust ssh-setup)
[[ -S "$SSH_AUTH_SOCK" ]] && { ssh-add -l &>/dev/null || SSH_ASKPASS_REQUIRE=never ssh-add ~/.ssh/id_ed25519 &>/dev/null; }

# headroom wrap for claude
export HEADROOM_REQUIRE_RUST_CORE=false
function claude() {
    if command -v headroom >/dev/null; then
        headroom wrap claude "$@"
    else
        command claude "$@"
    fi
}

# Local LLM (Ramalama / OpenCode / Aider) — §2.B, §2.D, §2.F
export OPENAI_API_KEY=sk-6869f13e80764e0ab07cb09a9ef5ea98
RAMA_IMG=docker.io/kyuz0/amd-strix-halo-toolboxes:vulkan-radv
MTP_OPTS="--spec-type draft-mtp --spec-draft-n-max 2 --spec-draft-p-min 0.75"
CTX=131072  # context window for the server (applies to ALL clients: WebUI, OpenCode, etc.)

# Stop the MAIN-model container (only) AND wait for :8080 to release before re-serving.
# Stops just 'llm' (not --all) so the :8081 autocomplete model survives a main-model swap.
# Without the wait, ramalama serve races the old socket, finds 8080 "busy", and
# silently auto-assigns a random port — breaking every client (WebUI/OpenCode/aider).
_llm_reset() {
  ramalama stop llm 2>/dev/null
  local i=0
  while ss -tln 2>/dev/null | grep -q ':8080 ' && (( i < 30 )); do sleep 0.5; (( i++ )); done
}

serve-llm() {
  _llm_reset
  ramalama serve -d -n llm -p 8080 --image "$RAMA_IMG" --ctx-size "$CTX" --runtime-args "$MTP_OPTS" "$1" \
    && echo "▶ serving $1 (MTP, ctx $CTX) at http://localhost:8080/v1"
}
serve-llm-nospec() {  # same model, MTP off — for quality A/B vs the MTP-on alias
  _llm_reset
  ramalama serve -d -n llm -p 8080 --image "$RAMA_IMG" --ctx-size "$CTX" "$1" \
    && echo "▶ serving $1 (no MTP, ctx $CTX) at http://localhost:8080/v1"
}
# Three "main models" — they swap through the one :8080 slot (container 'llm'), one at a time:
#   serve-code  → fast MoE, everyday agentic driver (OpenCode/Aider/terminal)
#   serve-think → dense reasoning, high-stakes paper critique/synthesis
#   serve-edit  → Gemma 4 31B, copyediting + hard statistical/math coding (NOT agentic loops)
alias serve-code='serve-llm hf://unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q8_K_XL'
alias serve-code-nospec='serve-llm-nospec hf://unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q8_K_XL'
alias serve-think='serve-llm hf://unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q8_K_XL'
alias serve-edit='serve-llm-nospec hf://unsloth/gemma-4-31b-it-GGUF:Q8_0'
alias stop-main='ramalama stop llm'  # stops whichever main model (:8080) is loaded

# Small FIM autocomplete model for Zed (Continue → :8081). Runs on the iGPU ALONGSIDE
# the main model, on its own name/port so a main-model swap doesn't evict it. No MTP (not an
# MTP build); small ctx since autocomplete prompts are short. The NPU has no coder model, so
# real code completion has to live on the iGPU — §2.J / §8.E.2. Served id: Qwen/Qwen2.5-Coder-1.5B-Instruct-GGUF
AUTOCOMPLETE_MODEL=hf://Qwen/Qwen2.5-Coder-1.5B-Instruct-GGUF:Q4_K_M
serve-autocomplete() {
  ramalama stop coder 2>/dev/null
  local i=0
  while ss -tln 2>/dev/null | grep -q ':8081 ' && (( i < 30 )); do sleep 0.5; (( i++ )); done
  ramalama serve -d -n coder -p 8081 --image "$RAMA_IMG" --ctx-size 8192 "$AUTOCOMPLETE_MODEL" \
    && echo "▶ serving autocomplete (FIM) at http://localhost:8081/v1"
}
alias stop-autocomplete='ramalama stop coder'

# Serve an embedder model on the iGPU alongside the main model and autocomplete
EMBED_MODEL="hf://Qwen/Qwen3-Embedding-8B-GGUF:Q4_K_M"
serve-embedder() {
  ramalama stop embedder 2>/dev/null
  local i=0
  while ss -tln 2>/dev/null | grep -q ':8082 ' && (( i < 30 )); do sleep 0.5; (( i++ )); done
  ramalama serve -d -n embedder -p 8082 --image "$RAMA_IMG" --ctx-size 8192 --runtime-args="--embedding" "$EMBED_MODEL" \
    && echo "▶ serving embedder at http://localhost:8082/v1"
}
alias stop-embedder="ramalama stop embedder"

# Show which model is actually loaded on each port (id from /v1/models = source of truth).
# Tags the chat port MoE/dense: an "A<N>B" suffix (active params) = MoE, plain count = dense.
model-check() {
  local p name id tag
  for entry in "8080:main" "8081:autocomplete" "8082:embedder"; do
    p="${entry%%:*}"; name="${entry##*:}"
    id=$(curl -sf "http://localhost:$p/v1/models" 2>/dev/null \
           | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)
    if [[ -z "$id" ]]; then
      printf '  :%s  %-13s —\n' "$p" "$name"
    else
      tag=""
      [[ "$p" == 8080 ]] && { [[ "$id" == *A[0-9]*B* ]] && tag=" (MoE)" || tag=" (dense)"; }
      printf '  :%s  %-13s %s%s\n' "$p" "$name" "$id" "$tag"
    fi
  done
}


alias opencode-rebuild='podman build --no-cache -t localhost/opencode-safe:latest "$HOME/.config/opencode"'

opencode-safe-1() {
  local target_dir="${1:-$PWD}"
  local abs_dir="$(realpath "$target_dir")"

  if [[ "$abs_dir" == "$HOME" ]]; then
    echo "Error: Cannot run opencode-safe-1 with write access to your entire home directory."
    return 1
  fi

  echo -e "\033[33mWARNING: You are giving OpenCode WRITE access to directory: $abs_dir (including subdirectories)\033[0m"
  echo -e "\033[33mAnd READ access to everywhere else in: $HOME\033[0m"
  if read -q "choice?Do you want to proceed? [y/N] "; then
    echo
  else
    echo -e "\nAborted."
    return 1
  fi

  podman run -it --rm \
    --network=host \
    --userns=keep-id \
    --security-opt label=disable \
    -e HOME="$HOME" \
    -v "$HOME":"$HOME":ro \
    -v "$abs_dir":"$abs_dir" \
    -v "$HOME/.config/opencode":"$HOME/.config/opencode":ro \
    -v "$HOME/.local/share/opencode":"$HOME/.local/share/opencode" \
    -v "$HOME/.local/state/opencode":"$HOME/.local/state/opencode" \
    -v "$HOME/.cache/opencode":"$HOME/.cache/opencode" \
    -w "$abs_dir" \
    localhost/opencode-safe:latest "${@:2}"
}

opencode-safe-2() {
  local target_dir="${1:-$PWD}"
  local abs_dir="$(realpath "$target_dir")"

  if [[ "$abs_dir" == "$HOME" ]]; then
    echo "Error: Cannot run opencode-safe-2 with write access to your entire home directory."
    return 1
  fi

  echo -e "\033[33mWARNING: You are giving OpenCode WRITE access to directory: $abs_dir (including subdirectories)\033[0m"
  echo -e "\033[33mOpenCode will have NO read access to the rest of the system.\033[0m"
  if read -q "choice?Do you want to proceed? [y/N] "; then
    echo
  else
    echo -e "\nAborted."
    return 1
  fi

  podman run -it --rm \
    --network=host \
    --userns=keep-id \
    --security-opt label=disable \
    -e HOME="$HOME" \
    -v "$abs_dir":"$abs_dir" \
    -v "$HOME/.config/opencode":"$HOME/.config/opencode":ro \
    -v "$HOME/.local/share/opencode":"$HOME/.local/share/opencode" \
    -v "$HOME/.local/state/opencode":"$HOME/.local/state/opencode" \
    -v "$HOME/.cache/opencode":"$HOME/.cache/opencode" \
    -w "$abs_dir" \
    localhost/opencode-safe:latest "${@:2}"
}

opencode-safe-3() {
  local target_file="${1}"

  if [[ -z "$target_file" || ! -f "$target_file" ]]; then
    echo "Error: opencode-safe-3 requires a specific existing FILE as an argument."
    echo "Usage: opencode-safe-3 /path/to/file.ext [args...]"
    return 1
  fi

  local abs_file="$(realpath "$target_file")"
  local abs_dir="$(dirname "$abs_file")"

  echo -e "\033[33mWARNING: You are giving OpenCode READ/WRITE access to exactly ONE FILE: $abs_file\033[0m"
  echo -e "\033[33mOpenCode will have NO access anywhere else (writable /tmp only).\033[0m"
  if read -q "choice?Do you want to proceed? [y/N] "; then
    echo
  else
    echo -e "\nAborted."
    return 1
  fi

  podman run -it --rm \
    --network=host \
    --userns=keep-id \
    --security-opt label=disable \
    -e HOME="$HOME" \
    -v "$abs_file":"$abs_file" \
    -v "$HOME/.config/opencode":"$HOME/.config/opencode":ro \
    -v "$HOME/.local/share/opencode":"$HOME/.local/share/opencode" \
    -v "$HOME/.local/state/opencode":"$HOME/.local/state/opencode" \
    -v "$HOME/.cache/opencode":"$HOME/.cache/opencode" \
    --tmpfs /tmp \
    -w "$abs_dir" \
    localhost/opencode-safe:latest "${@:2}"
}
