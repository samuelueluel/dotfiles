  source "$ZSH_CACHE/atuin.zsh"
fi

# fzf keybindings/completion
for f in /usr/share/fzf/shell/key-bindings.zsh /usr/share/fzf/shell/completion.zsh; do
  [ -f "$f" ] && source "$f"
