# Show which model is actually loaded on each port (id from /v1/models = source of truth).
# Tags the chat port MoE/dense: an "A<N>B" suffix (active params) = MoE, plain count = dense.
model-check() {
  local p name id tag
  for entry in "8080:main" "8081:autocomplete" "8082:embedder"; do
    p="${entry%%:*}"; name="${entry##*:}"
    id=$(curl -sf "http://localhost:$p/v1/models" 2>/dev/null \
           | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)
    if [[ -z "$id" ]]; then
      printf '  :%s  %-13s —\n' "$p" "$name"
    else
      tag=""
      [[ "$p" == 8080 ]] && { [[ "$id" == *A[0-9]*B* ]] && tag=" (MoE)" || tag=" (dense)"; }
      printf '  :%s  %-13s %s%s\n' "$p" "$name" "$id" "$tag"
    fi
  done
}

goose-with() {
  _llm_reset
  ramalama serve -d -n llm -p 8080 --image "$RAMA_IMG" --ctx-size "$CTX" --runtime-args "$MTP_OPTS" "$1" || return 1
  until curl -sf http://localhost:8080/v1/models >/dev/null 2>&1; do sleep 0.5; done
  local model_name=$(curl -sf http://localhost:8080/v1/models | python3 -c "import sys, json; print(json.load(sys.stdin)['data'][0]['id'])" 2>/dev/null)
  goose session --openai-host http://localhost:8080/v1 --openai-model "$model_name"
}
alias goose-code='goose-with hf://unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q8_K_XL'
alias goose-think='goose-with hf://unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q8_K_XL'

