# --- GOOSE ALIASES ---

alias goose-rebuild='podman build --no-cache -t localhost/goose-safe:latest "$HOME/.config/goose"'

_goose_resolve_params() {
  # 1. Query active model from local Ramalama instance
  local model_id
  model_id=$(curl -sf "http://localhost:8080/v1/models" 2>/dev/null \
         | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)

  # 2. Defaults (aligned with opencode.jsonc)
  local ctx_limit=131072
  local max_tokens=16384
  local temp=0.6

  if [[ "$model_id" == *Qwen3.6-35B-A3B* ]]; then
    ctx_limit=131072
    max_tokens=16384
  elif [[ "$model_id" == *Qwen3.6-27B* ]]; then
    ctx_limit=131072
    max_tokens=16384
  elif [[ "$model_id" == *gemma-4-31b* ]]; then
    ctx_limit=131072
    max_tokens=16384
  fi

  export GOOSE_CONTEXT_LIMIT="$ctx_limit"
  export GOOSE_MAX_TOKENS="$max_tokens"
  export GOOSE_TEMPERATURE="$temp"
  export GOOSE_MODE="smart_approve"
}

goose() {
  local clean_args=()
  local skills=()
  
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --skill)
        skills+=("$2")
        shift 2
        ;;
      *)
        clean_args+=("$1")
        shift
        ;;
    esac
  done

  _goose_resolve_params

  local tmpfile=""
  if [[ ${#skills[@]} -gt 0 ]]; then
    tmpfile="/tmp/goose_skills_$$"
    cat "${skills[@]}" > "$tmpfile"
    
    GOOSE_MOIM_MESSAGE_FILE="$tmpfile" command goose "${clean_args[@]}"
    local ret=$?
    rm -f "$tmpfile"
    return $ret
  else
    command goose "${clean_args[@]}"
  fi
}

