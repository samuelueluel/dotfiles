# ============================================================
# AGENT LAUNCH COMMANDS
# ============================================================
# pi      = local model, Stata skills/binary excluded, optional sandboxing
# pihat   = cloud model, Stata skills/binary excluded, optional sandboxing
# beta    = local model, Stata skills + MCP + binary,  always sandboxed
# betahat = cloud model, Stata skills + MCP + binary,  always sandboxed
#
# "Stata skills/binary excluded": no Stata skill files loaded, MCP will not start,
#   Stata binary never mounted. Use for general coding tasks.
# "Stata skills + MCP + binary": all Stata skills and MCP config loaded;
#   /usr/local/stata19 mounted so the agent can actually run do-files.
#
# pihat / betahat write a state file to ~/.pi/running/ for status monitoring.

# Helper: populate global _PI_SKILL_ARGS with --no-skills + --skill for all skills except stata*
_pi_nonstata_skills() {
  typeset -ga _PI_SKILL_ARGS
  _PI_SKILL_ARGS=("--no-skills")
  local s
  for s in ~/.agents/skills/*; do
    [[ -d "$s" ]] || continue
    [[ "${s:t}" == stata* ]] && continue
    _PI_SKILL_ARGS+=("--skill" "$s")
  done
  for s in ~/.pi/agent/skills/*; do
    [[ -d "$s" ]] || continue
    _PI_SKILL_ARGS+=("--skill" "$s")
  done
}

# --- LEMONADE HELPERS ---
LEM_API="http://127.0.0.1:13305/api/v1"

# lem-status: show all loaded models across every slot category, not just the LLM
lem-status() {
  local out
  out=$(curl -s -m 5 "$LEM_API/health" 2>/dev/null) || { echo "Lemonade not reachable on $LEM_API"; return 1; }
  [[ -z "$out" ]] && { echo "Lemonade not reachable on $LEM_API"; return 1; }
  print -r -- "$out" | python3 -c '
import sys, json
d = json.load(sys.stdin)
loaded = d.get("all_models_loaded") or []
print("server: %s  (v%s)" % (d.get("status", "?"), d.get("version", "?")))
if not loaded:
    print("loaded: none (RAM clear)")
else:
    print("loaded models:")
    for m in loaded:
        pin = " [pinned]" if m.get("pinned") else ""
        print("  - %-11s %s  (%s, %s)%s" % (
            m.get("type", "?"), m.get("model_name", "?"),
            m.get("device", "?"), m.get("status", "?"), pin))
mm = d.get("max_models") or {}
counts = {}
for m in loaded:
    counts[m.get("type", "?")] = counts.get(m.get("type", "?"), 0) + 1
print("slots (loaded/max): " + "  ".join(
    "%s=%d/%s" % (k, counts.get(k, 0), v) for k, v in mm.items()))
'
}

# lem-unload: drop ALL models from RAM (server stays up, weights stay on disk)
lem-unload() {
  local out
  out=$(curl -s -m 10 -X POST "$LEM_API/unload" -H 'Content-Type: application/json' -d '{}' 2>/dev/null) \
    || { echo "Lemonade not reachable on $LEM_API"; return 1; }
  print -r -- "$out" | python3 -c 'import sys, json; print(json.load(sys.stdin).get("message", "(no response)"))' 2>/dev/null \
    || print -r -- "$out"
}

_pi_pick_local_model() {
  local choice
  choice=$(gum choose --header "select model  (Lemonade · one loads at a time)" \
    "moe-q4     Qwen3.6 MoE 35B    Q4" \
    "moe-q8     Qwen3.6 MoE 35B    Q8" \
    "dense-q4   Qwen3.6 Dense 27B  Q4" \
    "dense-q8   Qwen3.6 Dense 27B  Q8") || return 1
  case "${choice%%[ ]*}" in
    moe-q4)   print -r -- "Qwen3.6-MoE-35B-Q4" ;;
    moe-q8)   print -r -- "Qwen3.6-MoE-35B-Q8" ;;
    dense-q4) print -r -- "Qwen3.6-Dense-27B-Q4" ;;
    dense-q8) print -r -- "Qwen3.6-Dense-27B-Q8" ;;
    *) return 1 ;;
  esac
}

# _lem_preload <model_id>: pick MTP (Qwen only) + parallel, then load the model
# with those as a flag-level override merged over its saved recipe, so the agent
# connects to exactly the config chosen here.
_lem_preload() {
  local id="$1" args="" mtp par
  # real reachability check first, so a slow load is not mistaken for a dead server
  if ! curl -s -m 5 "$LEM_API/health" >/dev/null 2>&1; then
    print -r -- "Lemonade not reachable on $LEM_API (container up? try 'podman start lemonade')"
    return 1
  fi
  if [[ "$id" == Qwen* ]]; then
    mtp=$(gum choose --header "MTP speculative decoding" --selected "on" "on" "off") || return 1
    [[ "$mtp" == "off" ]] && args+=" --spec-type none"
  fi
  par=$(gum choose --header "parallel slots" --selected "1" "1" "2") || return 1
  args+=" --parallel $par"
  args="${args# }"

  # if the weights are not downloaded yet, the load also pulls them (can be tens of GB)
  local note="loading ${id}  [override: ${args}]"
  curl -s -m 10 "$LEM_API/models" 2>/dev/null | grep -q "\"$id\"" \
    || note="first load of ${id}: downloading weights (several minutes) then loading  [override: ${args}]"

  local resp
  resp=$(gum spin --show-output --title "$note" -- \
    curl -s -m 1800 -X POST "$LEM_API/load" -H 'Content-Type: application/json' \
    -d "{\"model_name\":\"${id}\",\"llamacpp_args\":\"${args}\"}")
  print -r -- "$resp" | grep -q '"status":"success"' && return 0
  print -r -- "load failed: ${resp:-timed out; check 'podman logs lemonade' or 'lem-status'}"
  return 1
}

pi() {
  _pi_nonstata_skills

  local model_id
  model_id=$(_pi_pick_local_model) || return 1
  _lem_preload "$model_id" || return 1
  local model_flag="local/$model_id"

  local go
  go=$(gum choose --header "pi · run in container?" \
    "no   unsandboxed" \
    "yes  sandboxed") || return 1

  case "${go%%[ ]*}" in
    no)
      command pi "${_PI_SKILL_ARGS[@]}" --model "$model_flag" "$@"
      ;;
    yes)
      local target="${1:-$PWD}" abs_target is_file=0
      abs_target="$(realpath "$target" 2>/dev/null)" || { echo "Error: cannot resolve '$target'"; return 1; }
      [[ -f "$abs_target" ]] && is_file=1

      local level
      level=$(gum choose --header "pi · isolation level" \
        "1   write to dir  +  read all of \$HOME" \
        "2   write to dir  +  no read elsewhere" \
        "3   write to single file only") || return 1
      level="${level%%[ ]*}"

      if [[ "$level" == "3" ]] && (( !is_file )); then
        echo "Error: level 3 requires a file path, not a directory."; return 1
      fi

      pi-safe-${level} "${abs_target}" "${_PI_SKILL_ARGS[@]}" --model "$model_flag" "${@:2}"
      ;;
  esac
}

pihat() {
  local model_choice model_key model_flag default_thinking thinking_choice
  local -a thinking_opts

  model_choice=$(gum choose \
    --header "pihat · select model" \
    "dsv4pro   DeepSeek V4 Pro" \
    "dsv4fl    DeepSeek V4 Flash" \
    "opus      Claude Opus 4.8" \
    "glm52     GLM 5.2") || return 1
  [[ -z "$model_choice" ]] && return 1

  model_key="${model_choice%%[ ]*}"
  case "$model_key" in
    dsv4pro) 
      model_flag="openrouter/deepseek/deepseek-v4-pro"
      default_thinking="xhigh"
      thinking_opts=("high" "xhigh")
      export OPENROUTER_API_KEY="$OPENROUTER_API_KEY_DS"
      ;;
    dsv4fl)  
      model_flag="openrouter/deepseek/deepseek-v4-flash"
      default_thinking="xhigh"
      thinking_opts=("high" "xhigh")
      export OPENROUTER_API_KEY="$OPENROUTER_API_KEY_DS"
      ;;
    opus)
      model_flag="openrouter/anthropic/claude-opus-4.8"
      default_thinking="high"
      thinking_opts=("low" "medium" "high")
      export OPENROUTER_API_KEY="$OPENROUTER_API_KEY_US"
      ;;
    glm52)
      model_flag="openrouter/z-ai/glm-5.2"
      default_thinking="xhigh"
      thinking_opts=("high" "xhigh")
      export OPENROUTER_API_KEY="$OPENROUTER_API_KEY_US"
      ;;
    *)       return 1 ;;
  esac

  thinking_choice=$(gum choose \
    --header "pihat · thinking effort  (default: $default_thinking)" \
    --selected "$default_thinking" \
    "${thinking_opts[@]}") || return 1
  [[ -z "$thinking_choice" ]] && return 1

  _pi_nonstata_skills

  local go
  go=$(gum choose --header "pihat · run in container?" \
    "no   unsandboxed" \
    "yes  sandboxed") || return 1

  local _state_dir="$HOME/.pi/running"
  mkdir -p "$_state_dir"
  local _state_file="$_state_dir/$$.state"
  printf 'type=pihat\nmodel=%s\nthinking=%s\n' "$model_flag" "$thinking_choice" > "$_state_file"

  case "${go%%[ ]*}" in
    no)
      { command pi "${_PI_SKILL_ARGS[@]}" --model "$model_flag" --thinking "$thinking_choice" "$@" } \
        always { rm -f "$_state_file" }
      ;;
    yes)
      local target="${1:-$PWD}" abs_target is_file=0
      abs_target="$(realpath "$target" 2>/dev/null)" || { echo "Error: cannot resolve '$target'"; return 1; }
      [[ -f "$abs_target" ]] && is_file=1

      local level
      level=$(gum choose --header "pihat · isolation level" \
        "1   write to dir  +  read all of \$HOME" \
        "2   write to dir  +  no read elsewhere" \
        "3   write to single file only") || return 1
      level="${level%%[ ]*}"

      if [[ "$level" == "3" ]] && (( !is_file )); then
        echo "Error: level 3 requires a file path, not a directory."; return 1
      fi

      { pi-safe-${level} "${abs_target}" "${_PI_SKILL_ARGS[@]}" --model "$model_flag" --thinking "$thinking_choice" "${@:2}" } \
        always { rm -f "$_state_file" }
      ;;
  esac
}

